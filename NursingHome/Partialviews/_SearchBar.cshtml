

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="row p-2" style="display:flex;justify-content:space-evenly">
                        <!-- Date Range Picker Columns -->
                        <div class="col-3 row">
                            <div class="col-4">
                                <label class="mt-1">Start Date:</label>
                            </div>
                            <div class="col-8">
                                <input type="datetime-local" id="startDate" class="form-control" />
                            </div>
                        </div>
                        <div class="col-3 row">
                            <div class="col-4">
                                <label class="mt-1">End Date:</label>
                            </div>
                            <div class="col-8">
                                <input type="datetime-local" id="endDate" class="form-control" />
                            </div>
                        </div>
                        <!-- Multi-select Dropdown Columns -->
                        <div class="col-4 row">
                            <div class="col-4">
                                <label for="multiSelect" class="mt-1">Select User:</label>
                            </div>
                            <div class="col-8">
                                <select id="multiSelect" multiple="multiple"></select>
                            </div>
                        </div>
                        <!-- Button Column -->
                        <div class="col-2">
                            <button id="btnSubmit" class="btn btn-info">Submit</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>


    // Initialize Multi-select Dropdown
    $(function () {
        $('#multiSelect').multiselect({
            includeSelectAllOption: true // Optional: Include a "Select All" option
        });
    });
</script>