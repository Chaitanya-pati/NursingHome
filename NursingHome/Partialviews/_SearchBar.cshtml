
<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card" style="background-color:#f7f6fa">
                <div class="card-body">
                    <div class="row p-2" style="display:flex;justify-content:space-evenly">
                        <!-- Date Range Picker Columns -->
                        <input type="hidden" id="titlename" value="@ViewData["Title"]"/>
                        <div class="col-4 row">
                            <div class="col-4">
                                <label class="mt-1">Start Date:</label>
                            </div>
                            <div class="col-8">
                                <input type="datetime-local" id="startDate" class="form-control" />
                            </div>
                        </div>
                        <div class="col-4 row">
                            <div class="col-4">
                                <label class="mt-1">End Date:</label>
                            </div>
                            <div class="col-8">
                                <input type="datetime-local" id="endDate" class="form-control" />
                            </div>
                        </div>
                        <!-- Multi-select Dropdown Columns -->
                        <div class="col-3 row" id="userColumn" hidden>
                            <div class="col-4">
                                <label class="mt-1">Select User:</label>
                            </div>
                            <div class="col-8">
                                <select id="ddlUsers" class="form-select">
                                </select>
                            </div>
                        </div>
                        <!-- Button Column -->
                        <div class="col-1">
                            <button id="search" class="customBtn">Search</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>


    document.addEventListener('DOMContentLoaded', (event) => {
        document.getElementById('startDate').value = GetFormattedStartDate(new Date());
        document.getElementById('endDate').value = GetFormatedDateValue(new Date());

        $('#startDate').on('change', function () {
            checkrange('startDate', 'endDate');
        });
        $('#endDate').on('change', function () {
            checkrange('startDate', 'endDate');
        });

        if (localStorage.getItem('userRole') == 'admin'){
            $('#userColumn').prop('hidden',false);
        }

        $.ajax({
            url: '/Users/GetData',
            type: 'GET', 
            dataType: 'json', 
            success: function (response) {
                BindUserDropdownSeachBar(response.data); 
            },
            error: function (xhr, status, error) {
                console.error(xhr.responseText);
            }
        });
    });
    function BindUserDropdownSeachBar(data) {
        const ddlUsers = document.getElementById("ddlUsers");

        ddlUsers.innerHTML = "";

        const defaultOption = document.createElement("option");
        defaultOption.text = "Select User";
        defaultOption.value = "";
        ddlUsers.appendChild(defaultOption);

        data.forEach(item => {
            const option = document.createElement("option");
            option.value = item.userName;
            option.text = item.firstName + " " + item.lastName;
            ddlUsers.appendChild(option);
        });

        $('#ddlUsers').val(localStorage.getItem('username'));
        if($('#titlename').val() == "OldAge" || $('#titlename').val() == "Nursing Home"){
        GetData();
        }
    }
    function sendWhatsapp() {
        var phonenumber = "+919972148686";

        // Hardcoded message with bold headings
        var message =
            "*Name:* John Doe%0a" +  // Name
            "*Email:* johndoe@example.com%0a" + // Email
            "*Country:* USA%0a" +  // Country
            "*Message:* This is a sample message sent from the JavaScript application."; // Sample message

        var url = "https://wa.me/" + phonenumber + "?text=" + message;

        window.open(url, "_blank").focus();
    }

</script>