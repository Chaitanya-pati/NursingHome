
<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card" style="background-color:#f7f6fa">
                <div class="card-body">
                    <div class="row p-2" style="display:flex;justify-content:space-between">
                        <!-- Date Range Picker Columns -->
                        <input type="hidden" id="titlename" value="@ViewData["Title"]" />
                        <div class="col-lg-4 col-md-6 col-sm-6 col-xs-6 row">
                            <div class="col-4 mt-2">
                                <label class="mt-1">Start Date:</label>
                            </div>
                            <div class="col-8 mt-2">
                                <input type="datetime-local" id="startDate" class="form-control" />
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-6 col-sm-6 col-xs-6  row">
                            <div class="col-4 mt-2">
                                <label class="mt-1">End Date:</label>
                            </div>
                            <div class="col-8 mt-2">
                                <input type="datetime-local" id="endDate" class="form-control" />
                            </div>
                        </div>
                        <!-- Multi-select Dropdown Columns -->
                        <div class="col-lg-3 col-md-6 col-sm-6 col-xs-6 row" id="userColumn" hidden>
                            <div class="col-4 mt-2">
                                <label class="mt-1">Select User:</label>
                            </div>
                            <div class="col-8 mt-2">
                                <select id="ddlUsers" class="form-select">
                                </select>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 col-sm-6 col-xs-6 row" id="helperColumn" hidden>
                            <div class="col-4">
                                <label class="mt-1">Select Helper:</label>
                            </div>
                            <div class="col-8">
                                <select id="ddlHelper" class="form-select">
                                </select>
                            </div>
                        </div>
                        <!-- Button Column -->
                        <div class="col-lg-1 col-md-2 col-sm-4 col-xs-4 mt-2">
                            <button id="search" class="customBtn">Search</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Modal popup -->
<div id="imageModal" class="modal" tabindex="-1" role="dialog" style="z-index:9999  ">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">QR Code</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <img id="imgQrCode" src="" style="width: 100%; height: 100%;">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
<script>


    document.addEventListener('DOMContentLoaded', (event) => {
        document.getElementById('startDate').value = GetFormattedStartDate(new Date());
        document.getElementById('endDate').value = GetFormatedDateValue(new Date());

        $('#startDate').on('change', function () {
            checkrange('startDate', 'endDate');
        });
        $('#endDate').on('change', function () {
            checkrange('startDate', 'endDate');
        });

        if (localStorage.getItem('userRole') == 'admin' && $('#titlename').val() != "Attendance") {
            $('#userColumn').prop('hidden', false);
        }
        if ($('#titlename').val() == "Attendance") {
            $('#helperColumn').prop('hidden', false);
        }
        $.ajax({
            url: '/Users/GetData',
            type: 'GET',
            dataType: 'json',
            success: function (response) {
                BindUserDropdownSeachBar(response.data);
            },
            error: function (xhr, status, error) {
                console.error(xhr.responseText);
            }
        });
        GetCityDetails();
    });
    function BindUserDropdownSeachBar(data) {
        const ddlUsers = document.getElementById("ddlUsers");

        ddlUsers.innerHTML = "";

        const defaultOption = document.createElement("option");
        defaultOption.text = "Select User";
        defaultOption.value = "";
        ddlUsers.appendChild(defaultOption);

        data.forEach(item => {
            const option = document.createElement("option");
            option.value = item.userName;
            option.text = item.firstName + " " + item.lastName;
            ddlUsers.appendChild(option);
        });

        $('#ddlUsers').val(localStorage.getItem('username'));
        if ($('#titlename').val() == "OldAge" || $('#titlename').val() == "Nursing Home") {
            GetData();
        }
    }
    function sendWhatsapp() {
        var phonenumber = "+919972148686";

        // Hardcoded message with bold headings
        var message =
            "*Name:* John Doe%0a" +  // Name
            "*Email:* johndoe@example.com%0a" + // Email
            "*Country:* USA%0a" +  // Country
            "*Message:* This is a sample message sent from the JavaScript application."; // Sample message

        var url = "https://wa.me/" + phonenumber + "?text=" + message;

        window.open(url, "_blank").focus();
    }
    function GetCityDetails() {
        let username = localStorage.getItem('username');
        $.ajax({
            url: '/Configuration/CityDetails',
            type: 'GET',
            dataType: 'json',
            data: { username: username },
            success: function (response) {
                if (response != null) {
                    $('#imgQrCode').attr('src', "data:image/*;base64," + response.imageBase64.split("~")[1]);
                    $('#customAdreesLine1').text(response.officeAddress);
                    $('#cutomMobileNumbers').text(response.mobileNumbers);
                    $('#customEmailAddress').text(response.email);
                }
            },
            error: function (xhr, status, error) {
                console.error(xhr.responseText);
            }
        });
    }
    function OpenQRPopup() {
        $('#imageModal').modal('toggle');
    }
</script>