                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body registrationFormContent">
                    <form>
                        <table class="table table-bordered">
                            <tbody>
                                <tr>
                                    <td colspan="2">
                                        <div class="row mt-2">
                                            <div class="col-3">
                                                <img src="~/images/plus icon.png" style="height:70px;width:90px" />
                                            </div>
