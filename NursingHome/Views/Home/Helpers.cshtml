                                                <label style="font-family:fantasy;font-size:50px;color:red;letter-spacing:5px">VEDHANTH</label>

                                            </div>
                                            <div class="col-3 contentEnd">
                                                <label for="upload-btn">
                                                    <img id="preview-image" style="height:80px;width:80px; cursor: pointer;border:1px solid;" onclick="chooseOption()" />
                                                </label>
                                                <input type="file" id="upload-btn" accept="image/*" style="display: none;" onchange="previewImage(event)">
                                            </div>

                                            <div class="col-2"></div>
