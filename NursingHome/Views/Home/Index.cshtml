@{
    ViewData["Title"] = "Home Page";
}
<style>
    /* Container styling */
    .container-fluid {
        padding: 20px;
    }

    /* Card styling */
    .card {
        border: none;
        border-radius: 10px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
        min-height: 200px; /* Ensuring cards are taller */
    }

    .card:hover {
        box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
        transform: translateY(-5px);
    }

    /* Header styling */
    .card-header {
        border-top-left-radius: 10px;
        border-top-right-radius: 10px;
        padding: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 1.2rem;
        color: #fff;
    }

    .card-body {
        padding: 20px;
        text-align: center;
    }

    /* Color Schemes */
    .green-header { background-image: linear-gradient(45deg, #4CAF50, #66BB6A); }
    .green-body { background-color: #E8F5E9; }

    .blue-header { background-image: linear-gradient(45deg, #2196F3, #42A5F5); }
    .blue-body { background-color: #E3F2FD; }

    .orange-header { background-image: linear-gradient(45deg, #FF9800, #FFA726); }
    .orange-body { background-color: #FFF3E0; }

    /* Data styling */
    h2 { font-size: 2.5rem; font-weight: bold; margin: 0; color: #333; }
    p.text-sm { font-size: 0.9rem; color: #777; }

    /* Button */
    .btn-view {
        margin-top: 15px;
        padding: 10px 20px;
        background-color: #007BFF;
        color: white;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        transition: 0.3s;
    }

    .btn-view:hover {
        background-color: #0056b3;
    }

    /* Charts/Graphs styling */
    .chart-section {
        margin-top: 30px;
        padding: 20px;
        background-color: #f9f9f9;
        border-radius: 10px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    }

    .chart-section h3 {
        text-align: center;
        margin-bottom: 20px;
    }

    /* Responsiveness */
    @@media (max-width: 768px) {
        h2 { font-size: 2rem; }
        p.text-sm { font-size: 0.85rem; }
    }
</style>

<div class="container-fluid">
    <div class="row">
        <!-- Green Card: Old Age Admission -->
        <div class="col-lg-4 col-md-6 col-sm-12 col-xs-12 mt-4">
            <div class="card">
                <div class="card-header green-header">
                    <h4 class="contentCenter"><i class="fa-solid fa-person-walking-with-cane"></i> Old Age Admission</h4>
                </div>
                <div class="card-body green-body">
                    <p class="text-sm">Total old age patients admitted in last 30 days</p>
                    <h2 id="oldAgeCount">0</h2>
                    <button class="btn-view">View Details</button>
                </div>
            </div>
        </div>

        <!-- Blue Card: Nursing Home Admission -->
        <div class="col-lg-4 col-md-6 col-sm-12 col-xs-12 mt-4">
            <div class="card">
                <div class="card-header blue-header">
                    <h4 class="contentCenter"><i class="fa-solid fa-hand-holding-medical"></i> Nursing Home Admission</h4>
                </div>
                <div class="card-body blue-body">
                    <p class="text-sm">Total Nursing Home patients admitted in last 30 days</p>
                    <h2 id="NursingCount">0</h2>
                    <button class="btn-view">View Details</button>
                </div>
            </div>
        </div>

        <!-- Orange Card: Helper Admission -->
        <div class="col-lg-4 col-md-6 col-sm-12 col-xs-12 mt-4">
            <div class="card">
                <div class="card-header orange-header">
                    <h4 class="contentCenter"><i class="fa-solid fa-user-doctor"></i> Helper Admission</h4>
                </div>
                <div class="card-body orange-body">
                    <p class="text-sm">Total Helpers Joined Till Today</p>
                    <h2 id="HelpersCount">0</h2>
                    <button class="btn-view">View Details</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Additional content: Charts or Graphs -->
    <div class="row mt-5">
        <div class="col-12 chart-section">
            <h3>Admission Trend Over Last 6 Months</h3>
            <canvas id="admissionChart"></canvas> <!-- Placeholder for a chart -->
        </div>
    </div>

    <!-- Additional Row: If you need more content -->
    <div class="row mt-4">
        <div class="col-md-6 col-sm-12 chart-section">
            <h3>Patient Age Demographics</h3>
            <canvas id="ageDemographicsChart"></canvas> <!-- Another placeholder for a chart -->
        </div>
        <div class="col-md-6 col-sm-12 chart-section">
            <h3>Helper Joining Rate</h3>
            <canvas id="helperJoiningChart"></canvas> <!-- Placeholder for another chart -->
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $.ajax({
            type: "GET",
            url: '/Home/GetLast30DaysRecords',
            success: function (response) {
                $('#oldAgeCount').text(response.oldAge);
                $('#NursingCount').text(response.nursingHome);
                $('#HelpersCount').text(response.helper);
            },
            error: function (response) {
                console.error(response);
            }
        });

        // Initialize chart data
        var ctx1 = document.getElementById('admissionChart').getContext('2d');
        var admissionChart = new Chart(ctx1, {
            type: 'line',
            data: {
                labels: ['April', 'May', 'June', 'July', 'August', 'September'],
                datasets: [{
                    label: 'Admissions',
                    data: [12, 19, 3, 5, 2, 3],
                    backgroundColor: 'rgba(54, 162, 235, 0.2)',
                    borderColor: 'rgba(54, 162, 235, 1)',
                    borderWidth: 1
                }]
            }
        });

        var ctx2 = document.getElementById('ageDemographicsChart').getContext('2d');
        var ageDemographicsChart = new Chart(ctx2, {
            type: 'doughnut',
            data: {
                labels: ['18-25', '26-35', '36-50', '51-65', '65+'],
                datasets: [{
                    label: 'Age Demographics',
                    data: [5, 10, 20, 15, 50],
                    backgroundColor: ['#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF']
                }]
            }
        });

        var ctx3 = document.getElementById('helperJoiningChart').getContext('2d');
        var helperJoiningChart = new Chart(ctx3, {
            type: 'bar',
            data: {
                labels: ['April', 'May', 'June', 'July', 'August', 'September'],
                datasets: [{
                    label: 'Helpers Joined',
                    data: [3, 4, 5, 2, 1, 6],
                    backgroundColor: 'rgba(255, 159, 64, 0.2)',
                    borderColor: 'rgba(255, 159, 64, 1)',
                    borderWidth: 1
                }]
            }
        });
    });
</script>
