
<head>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</head>


<div class="col-md-12">
    @Html.Partial("~/Partialviews/_SearchBar.cshtml")
</div>

<div class="container-fluid mt-3">
    <ul class="nav nav-tabs" id="myTab" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" id="oldAgeChartTab" data-toggle="tab" href="#oldAgeChartTabContent" role="tab"  aria-selected="true"> <i class="fa-solid fa-chart-column me-2"></i>OldAge</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" id="homeNursingChartTab" data-toggle="tab" href="#homeNursingChartTabContent" role="tab" aria-selected="false"><i class="fa-solid fa-chart-column me-2"></i>Home Nursing</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" id="helpersChartTab" data-toggle="tab" href="#helpersChartTabContent" role="tab" aria-selected="false"><i class="fa-solid fa-chart-column me-2"></i>Helpers</a>
        </li>

    </ul>
    <div class="tab-content mt-2" id="myTabContent">
        <div class="tab-pane fade show active" id="oldAgeChartTabContent" role="tabpanel" aria-labelledby="home-tab">
            <div class="container-fluid mb-2">
                <div class="card">
                    <div class="card-body">

                <canvas id="oldAgeChart"></canvas>

            </div>
            </div>
            </div>
            
        </div>
        <div class="tab-pane fade" id="homeNursingChartTabContent" role="tabpanel" aria-labelledby="profile-tab">
            <div class="container-fluid">
                <div class="card">
                    <div class="card-body">

                <canvas id="nursingHomeChart"></canvas>

            </div>
            </div>
            </div>


        </div>
        <div class="tab-pane fade" id="helpersChartTabContent" role="tabpanel" aria-labelledby="profile-tab">
            <div class="container-fluid">
                <div class="card">
                    <div class="card-body">

                <canvas id="helpersChart"></canvas>
                    </div>
                </div>
            </div>


        </div>

    </div>
</div>





<script>
    $(document).ready(function () {
        $('#userColumn').hide();
        $('#search').click(function () {
            fetchData();
        });
    });

    function fetchData() {
        const startDate = $('#startDate').val();
        const endDate = $('#endDate').val();

        $.ajax({
            url: `/Home/GetAdmissionData`,
            type: 'GET',
            data: { startDate: startDate, endDate: endDate },
            success: function (data) {
                console.log(data); // Log the data to inspect its structure

                // Extract data for each category
                const oldAgeData = data.oldAge || {};
                const nursingHomeData = data.nursingHome || {};
                const helpersData = data.helpers || {};

                // Prepare labels and counts for Old Age
                const oldAgeLabels = Object.keys(oldAgeData);
                const formattedOldAgeLabels = oldAgeLabels.map(dateStr => {
                    const date = new Date(dateStr);
                    return date.toLocaleDateString('en-GB'); // Format to dd/mm/yyyy
                });
                const oldAgeCounts = oldAgeLabels.map(date => oldAgeData[date] || 0);

                // Create Old Age Chart
                const ctxOldAge = document.getElementById('oldAgeChart').getContext('2d');
                new Chart(ctxOldAge, {
                    type: 'bar',
                    data: {
                        labels: formattedOldAgeLabels,
                        datasets: [{
                            label: 'Total Old Age Admissions',
                            data: oldAgeCounts,
                            backgroundColor: '#0080f2',
                        }]
                    },
                    options: {
                        scales: {
                            y: {
                                beginAtZero: true
                            }
                        }
                    }
                });

                // Prepare labels and counts for Nursing Home
                const nursingHomeLabels = Object.keys(nursingHomeData);
                const formattedNursingHomeLabels = nursingHomeLabels.map(dateStr => {
                    const date = new Date(dateStr);
                    return date.toLocaleDateString('en-GB'); // Format to dd/mm/yyyy
                });
                const nursingHomeCounts = nursingHomeLabels.map(date => nursingHomeData[date] || 0);

                // Create Nursing Home Chart
                const ctxNursingHome = document.getElementById('nursingHomeChart').getContext('2d');
                new Chart(ctxNursingHome, {
                    type: 'bar',
                    data: {
                        labels: formattedNursingHomeLabels,
                        datasets: [{
                            label: 'Total Nursing Home Admissions',
                            data: nursingHomeCounts,
                            backgroundColor: '#ff3800',
                        }]
                    },
                    options: {
                        scales: {
                            y: {
                                beginAtZero: true
                            }
                        }
                    }
                });

                // Prepare labels and counts for Helpers
                const helpersLabels = Object.keys(helpersData);
                const formattedHelpersLabels = helpersLabels.map(dateStr => {
                    const date = new Date(dateStr);
                    return date.toLocaleDateString('en-GB'); // Format to dd/mm/yyyy
                });
                const helpersCounts = helpersLabels.map(date => helpersData[date] || 0);

                // Create Helpers Chart
                const ctxHelpers = document.getElementById('helpersChart').getContext('2d');
                new Chart(ctxHelpers, {
                    type: 'bar',
                    data: {
                        labels: formattedHelpersLabels,
                        datasets: [{
                            label: 'Total Helpers Admissions',
                            data: helpersCounts,
                            backgroundColor: '#916630',
                        }]
                    },
                    options: {
                        scales: {
                            y: {
                                beginAtZero: true
                            }
                        }
                    }
                });
            },

            error: function (xhr, status, error) {
                console.error('Error fetching data:', error);
            }
        });
    }
</script>
