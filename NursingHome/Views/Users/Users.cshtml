    function downloadFile(base64String, fileType, fileName) {
        const link = document.createElement('a');
        link.href = `data:${fileType};base64,${base64String}`;
        link.download = fileName + fileType.split("/")[1];
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }
    function AddUser() {
        var formData = new FormData();
        formData.append('Id', $('#userId').val());
        formData.append('FirstName', $('#firstName').val());
        formData.append('LastName', $('#lastName').val());
        formData.append('UserName', $('#userName').val());
        formData.append('Password', $('#password').val());
        formData.append('Roles', $('#roles').val());
        formData.append('MobileNo', $('#mobileNo').val());
        formData.append('IdProof', userIdPrrof); // Assuming userIdPrrof is a file object or relevant data
        formData.append('ImageString', userImageString); // Assuming userImageString is a file object or relevant data
        formData.append('fkCity', $('#fkCity').val());
        formData.append('PinCode', $('#pinCode').val());
        formData.append('HighestQualification', $('#highestQualification').val());

        $.ajax({
            type: "POST",
            url: '@Url.Action("AddorEditUser", "Users")',
            data: formData,
           processData: false, // Required for FormData
            contentType: false, // Required for FormData
            success: function (response) {
                if (response) {
                    if ($('#userId').val() == '') {
                        msgPopup("success", "User Added Successfully");
                    } else {
                        msgPopup("success", "User Updated Successfully");
                    }
                }
                else {
                    msgPopup("error", "Error! Please Try Again");
                }
            },
            error: function (response) {

                console.error(response);
            }
        });
    }

    function GetUsersData() {
        var table = $('#tblUsers').DataTable();

        $.ajax({
            url: '/Users/GetData', // Ensure this URL is correct and matches your route
            type: 'GET', // Use GET method
            dataType: 'json', // Ensure the expected data type is JSON
            success: function (response) {
                table.clear();
                response.data.forEach(function (item) {
                    table.row.add([
                        item.firstName + " " + item.lastName, // Added a "+" sign between firstName and lastName
                        item.userName,
                        item.highestQualification,
                        item.roles,
                        item.mobileNo,
                        '<i class="fa fa-edit me-4 ml-2 btn-edit" style="color:green" data-full-data=\'' + JSON.stringify(item).replace(/'/g, "&#39;") + '\'></i>' +
                        '<i class="fa fa-trash ml-2 btn-delete" style="color:red" data-id="' + item.id + '"></i>' // Use data-id for storing the id attribute
                    ]).draw();
                });
                BindUserDropdown(response.data); // Call your dropdown binding function
            },
            error: function (xhr, status, error) {
                console.error(xhr.responseText); // Log detailed error info
            }
        });
    }

    function BindUserDropdown(data) {
        // Get the dropdown element by ID
        const ddlUsers = document.getElementById("ddlUsers");

        // Clear any existing options
        ddlUsers.innerHTML = "";

        // Add the default "Select User" option
        const defaultOption = document.createElement("option");
        defaultOption.text = "Select User";
        defaultOption.value = "";
        ddlUsers.appendChild(defaultOption);

        // Loop through the data and add options to the dropdown
        data.forEach(item => {
            const option = document.createElement("option");
            option.value = item.userName; // Set the value to userName
            option.text = item.firstName + " " + item.lastName; // Set the text to firstName + lastName
            ddlUsers.appendChild(option);
        });
    }

    async function setupCamera() {
        const video = document.getElementById('video');
        const stream = await navigator.mediaDevices.getUserMedia({ video: {} });
        video.srcObject = stream;
        return new Promise((resolve) => {
            video.onloadedmetadata = () => {
                video.play();
                resolve(video);
            };
        });
    }

    async function loadModels() {
        const MODEL_URL = 'https://raw.githubusercontent.com/justadudewhohacks/face-api.js/master/weights';

        await faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL);
        await faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL);
        await faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL);
    }

    async function registerFace() {
        const video = await setupCamera();
        console.log("Camera setup complete, starting face detection...");

        const detections = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions()).withFaceLandmarks().withFaceDescriptor();

        if (detections) {
            const descriptors = [detections.descriptor];
            const labeledDescriptors = new faceapi.LabeledFaceDescriptors('registeredFace', descriptors);
            userFaceDescriptor = JSON.stringify(labeledDescriptors);
            alertMessage('Face captured successfully!');
        } else {
            alertMessage('No face detected, please try again.');
        }
    }


    function SaveFaceDescriptor() {
        let username = $('#ddlUsers').val();
        if (username != '' && userFaceDescriptor != '') {
            $.ajax({
                type: "POST",
                url: '@Url.Action("SaveFaceDescriptor", "Users")',
                data: { username: username, face: userFaceDescriptor },
                success: function (response) {
                    if (response) {
                        msgPopup("success", "Face Data Added Successfully");
                    }
                    else {
                        msgPopup("error", "Error! Please Try Again");
                    }
                },
                error: function (response) {

                }
            });
        } else {
            alertMessage("Please Select User or Add face");
        }
    }
