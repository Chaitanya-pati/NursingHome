        $('#tblUsers').on('click', '.btn-delete', function () {
            var ID = JSON.parse($(this).attr('dataId'));
            confirmDelete(ID);
        });
        $('#idProof').on('change', function (event) {
            ConvertToBase64(event.target).then(base64 => {
                userIdPrrof = base64;
            });
        });
        $('#imageString').on('change', function (event) {
            ConvertToBase64(event.target).then(base64 => {
                userImageString = base64;
            });
        });
        $('#faceRecognition').on('click',function(){
            
        });
    });
    document.addEventListener('DOMContentLoaded', async () => {
        await loadModels();
        document.getElementById('captureFaceBtn').addEventListener('click', registerFace);
    });


    function OpenPopup() {
        $('.UserIPfields').val();
        userIdPrrof = '';
        userImageString = '';
        $('#userModal').modal('toggle');
    }
