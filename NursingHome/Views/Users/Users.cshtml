<style>
    #video-container {
        border: 1px solid black; /* Change color and size as needed */
        width: 100%;
        height: 400px;
        box-sizing: border-box; /* Ensures padding and border are included in the total width/height */
    }
</style>
<!-- Modal Structure -->
<div class="modal fade" id="userModal" role="dialog" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">User Information Form</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="row mb-3">
                        <!-- First Field Pair -->
                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-6">
                                    <label for="firstName" class="form-label">First Name</label>
                                </div>
                                <div class="col-md-6">
                                    <input type="text" id="userId" hidden class="UserIPfields">
                                    <input type="text" class="form-control UserIPfields" id="firstName">
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-6">
                                    <label for="lastName" class="form-label">Last Name</label>
                                </div>
                                <div class="col-md-6">
                                    <input type="text" class="form-control UserIPfields" id="lastName">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <!-- Second Field Pair -->
                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-6">
                                    <label for="userName" class="form-label">User Name</label>
                                </div>
                                <div class="col-md-6">
                                    <input type="text" class="form-control UserIPfields" id="userName">
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-6">
                                    <label for="password" class="form-label">Password</label>
                                </div>
                                <div class="col-md-6">
                                    <input type="password" class="form-control UserIPfields" id="password">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <!-- Third Field Pair -->
                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-6">
                                    <label for="roles" class="form-label">Roles</label>
                                </div>
                                <div class="col-md-6">
                                    <select class="form-select UserIPfields" id="roles">
                                        <option value="admin">Admin</option>
                                        <option value="supervisor">Supervisor</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-6">
                                    <label for="mobileNo" class="form-label">Mobile No</label>
                                </div>
                                <div class="col-md-6">
                                    <input type="text" class="form-control UserIPfields" id="mobileNo">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <!-- Fourth Field Pair -->
                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-6">
                                    <label for="imageString" class="form-label">Image String</label>
                                </div>
                                <div class="col-md-6">
                                    <input type="file" class="form-control" id="imageString">
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-6">
                                    <label for="idProof" class="form-label">ID Proof</label>
                                </div>
                                <div class="col-md-6">
                                    <input type="file" class="form-control" id="idProof">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <!-- Sixth Field Pair -->
                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-6">
                                    <label for="fkCity" class="form-label">City</label>
                                </div>
                                <div class="col-md-6">
                                    <select class="form-select UserIPfields" id="fkCity"></select>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-6">
                                    <label for="pinCode" class="form-label">Pin Code</label>
                                </div>
                                <div class="col-md-6">
                                    <input type="text" class="form-control UserIPfields" id="pinCode">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <!-- Seventh Field Pair -->
                        <div class="col-md-6">
                            <div class="row">
                                <div class="col-md-6">
                                    <label for="highestQualification" class="form-label">Highest Qualification</label>
                                </div>
                                <div class="col-md-6">
                                    <input type="text" class="form-control UserIPfields" id="highestQualification">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary" onclick="AddUser()">Save</button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>
<div class="container-fluid mt-3">
    <ul class="nav nav-tabs" id="myTab" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" id="usersTab" data-toggle="tab" href="#userTabContent" role="tab" aria-controls="home" aria-selected="true">Users</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" id="faceRecognition" data-toggle="tab" href="#facetabContent" role="tab" aria-controls="profile" aria-selected="false">Face Lock</a>
        </li>

    </ul>
    <div class="tab-content mt-2" id="myTabContent">
        <div class="tab-pane fade show active" id="userTabContent" role="tabpanel" aria-labelledby="home-tab">
            <div class="container-fluid mb-2 contentEnd">
                <button type="button" class="customBtn" data-bs-toggle="modal" data-target="#userModal" onclick="OpenPopup();">
                    <i class="fa fa-add me-1"></i>  ADD USER
                </button>
            </div>
            <table id="tblUsers" class="display table-bordered" style="width:100%">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>UserName</th>
                        <th>Qualification</th>
                        <th>Roles</th>
                        <th>Mobile No</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>
        <div class="tab-pane fade" id="facetabContent" role="tabpanel" aria-labelledby="profile-tab">
            <div class="container-fluid">
                <div class="row">
                    <div class="row col-12" style="display:flex;justify-content:space-evenly">
                        <div class="col-2">
                            <strong> Select User :</strong>
                        </div>
                        <div class="col-4">
                            <select class="form-select" id="ddlUsers"></select>
                        </div>
                        <div class="col-2">
                            <button id="captureFaceBtn" class="customBtn">Capture Face</button>
                        </div>
                    </div>
                    <div class="col-3"></div>
                    <div class="col-6 mt-4">
                        <div id="video-container">
                            <video id="video" style="width:100%" height="400" autoplay muted></video>
                        </div>
                    </div>
                    <div class="row contentCenter mt-2">
                        <div class="col-auto">
                            <button class="btn btn-success" onclick="SaveFaceDescriptor();">Save Fave</button>
                        </div>
                    </div>
                </div>
            </div>


        </div>
        <div class="tab-pane fade" id="contact" role="tabpanel" aria-labelledby="contact-tab">
            <h5>Contact</h5>
            <p>This is the contact tab content.</p>
        </div>
    </div>
</div>


