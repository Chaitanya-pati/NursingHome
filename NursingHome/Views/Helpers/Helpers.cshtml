<script>
    var candidateImage = "";
    var helperIdProof = "";

    $(document).ready(function () {
        GetData();
        GetCityDetails();
    });

    document.getElementById('downloadRegistrationForm').addEventListener('click', function () {
       
        const element = document.querySelector('.registrationFormContent');
        $('#siddhartname').text = "ವೇದಾಂತ್";
        element.style.transform = 'scale(1)';
        element.style.transformOrigin = 'top center';
        // Options for html2pdf
        const options = {
            margin: 0,
            filename: $('#candidateName').val() + '.pdf',
            image: { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 3 },
            jsPDF: { unit: 'in', format: 'letter', orientation: 'portrait' }
        };

        html2pdf().from(element).set(options).save().finally(() => {

            element.style.transform = '';
            element.style.transformOrigin = '';
        });
    });
    function chooseOption() {
        $.alert({
            content: 'Do you want to Upload an Image or Capture the face',
            typeAnimated: true,
            backgroundDismiss: false,
            backgroundDismissAnimation: 'glow',
            boxWidth: '30%',
            useBootstrap: false,
            buttons: {
                Yes: {
                    text: 'Upload from Device',
                    btnClass: 'btn btn-info',
                    action: function () {
                        document.getElementById('candidateImg').click();

                    },
                },
                No: {
                    text: 'Capture Image',
                    btnClass: 'btn btn-warning',
                    action: function () {
                        captureImage();
                    },
                },
            },
        });
    }

    function captureImage() {
        var constraints = {
            video: true
        };

        navigator.mediaDevices.getUserMedia(constraints)
            .then(function (stream) {
                var video = document.createElement('video');
                video.autoplay = true;
                video.srcObject = stream;

                var canvas = document.createElement('canvas');
                var context = canvas.getContext('2d');

                video.onloadedmetadata = function () {
                    canvas.width = video.videoWidth;
                    canvas.height = video.videoHeight;
                    context.drawImage(video, 0, 0, canvas.width, canvas.height);
                    var imageDataURL = canvas.toDataURL('image/png');

                    var output = document.getElementById('preview-image');
                    output.src = imageDataURL;

                    video.srcObject.getTracks().forEach(track => track.stop());
                };
            })
            .catch(function (error) {
                console.log('Error accessing camera: ', error);
            });
    }

    $('#idProof').on('change', function (event) {
        ConvertToBase64(event.target).then(base64 => {
            helperIdProof = base64;
        });
    });

    $('#candidateImg').on('change', function (event) {
        ConvertToBase64(event.target).then(base64 => {
            candidateImage = base64;
        });
    });

    $('#tblHelpers').on('click', '.btn-edit', function () {
        var fullData = JSON.parse($(this).attr('data-full-data'));
        BindData(fullData);
    });
    $('#tblHelpers').on('click', '.btn-delete', function () {
        var ID = JSON.parse($(this).attr('dataId'));
        confirmDelete(ID);
    });

    function previewImage(event) {
        var input = event.target;
        var reader = new FileReader();

        if (input.files && input.files[0]) {
            reader.onload = function (e) {
                var output = document.getElementById('preview-image');
                output.src = e.target.result;
            }

            reader.readAsDataURL(input.files[0]);
        } else {
            alert("Failed to load file");
        }
    }
    // CRUD Operation
    function AddHelper() {
        if (CheckEmptyFields()) {
            var data = {};
            data.Id = $('#helperId').val();
            data.Name = $('#candidateName').val();
            data.ParentName = $('#parentName').val();
            data.Image = candidateImage;
            data.DateOfBirth = $('#candidateDOB').val();
            data.MaritalStatus = $('#maritalStatus').val();
            data.PermanentAddress = $('#permanentAddress').val();
            data.PresentAddress = $('#presentAddress').val();
            data.IdProof = helperIdProof;
            data.Education = $('#education').val();
            data.LanguagesKnown = $('#languages').val();
            data.Experience = $('#experience').val();
            data.Salary = $('#salary').val();
            data.Reference = $('#referenceDetail').val();
            data.FamilyMembers = $('#famMembers').val();
            data.suser = localStorage.getItem('username');
            data.candidateSign = $('#clientSignature')[0].toDataURL("image/png").replace(/^data:image\/(png|jpg);base64,/, "");
            data.Place = $('#place').val();
            data.admissionDate = $('#admissionDate').val();
            $.ajax({
                type: "POST",
                url: '@Url.Action("AddorEditHelper", "Helpers")',
                data: data,
                success: function (response) {
                    if (response) {
                        let msg = $('#helperId').val() == '' ? "Data Added Successfully" : "Data Updated Successfully";
                        HidePopup('helperModal');
                        msgPopup("success", msg);
                        GetData();
                    } else {
                        msgPopup("error", "Error! Please Try Again");
                    }
                },
                error: function (response) {

                    console.error(response);
                }
            });
        }
    }

    function BindData(data) {
        $('#helperId').val(data.id);
        $('#candidateName').val(data.name);
        $('#parentName').val(data.parentName);
        $('#candidateImage').val(data.image);
        $('#candidateDOB').val(formatDate(new Date(data.dateOfBirth)));
        $('#maritalStatus').val(data.maritalStatus);
        $('#permanentAddress').val(data.permanentAddress);
        $('#presentAddress').val(data.presentAddress);
       // $('#helperIdProof').val(data.idProof);
       helperIdProof = data.idProof;
        if(data.image != null) {$('#preview-image').attr('src', 'data:image/png;base64,' + data.image.split("~")[1])};
        $('#education').val(data.education);
        $('#languages').val(data.languagesKnown);
        $('#experience').val(data.experience);
        $('#salary').val(data.salary);
        $('#referenceDetail').val(data.reference);
        $('#famMembers').val(data.familyMembers);
        $('#admissionDate').val(formatDate(new Date(data.admissionDate)));
        $('#bottomDate').val(formatDate(new Date(data.admissionDate)));
        $('#place').val(data.place);
        $('#clientSignatureImage').prop('hidden', false);
        $('#clientSignature').prop('hidden', true);
        $('#clientSignatureImage').attr('src', 'data:image/png;base64,' + data.candidateSign);
        showPopup('helperModal');
    }

    function GetData() {
        var table = $('#tblHelpers').DataTable();
        let UserName = 'admin';
        if (localStorage.getItem('userRole') != 'admin') {
            UserName = localStorage.getItem('username');
        }

        $.ajax({
            type: "POST",
            data: { UserName: UserName },
            url: '@Url.Action("GetData", "Helpers")',
            // data: data,
            success: function (response) {
                table.clear().draw();
                response.data.forEach(function (item) {
                    table.row.add([
                        item.name,
                        item.permanentAddress,
                        item.languagesKnown,
                        '<i class="fa fa-edit me-4 ml-2 btn-edit" style="color:green" data-full-data=\'' + JSON.stringify(item).replace(/'/g, "&#39;") + '\'></i>' +
                        '<i class="fa fa-trash ml-2 btn-delete"  style="color:red" dataId=\'' + JSON.stringify(item.id).replace(/'/g, "&#39;") + '\'></i>'
                    ]).draw();
                });
            },
            error: function (response) {

                console.error(response);
            }
        });
    }

    function ClearInputFields() {
        $('.inputFields').val('');
        candidateImage = "";
        helperIdProof = "";
        $('#adminssionDate').val(formatDate(new Date()));
        $('#preview-image').attr('src','');
        $('#clientSignature').prop('hidden', false);
        $('#clientSignatureImage').prop('hidden', true);
        showPopup('helperModal');
    }

    function confirmDelete(id) {
        $.alert({
            title: 'Alert',
            content: 'Are you sure want to delete ?',
            typeAnimated: true,
            backgroundDismiss: false,
            backgroundDismissAnimation: 'glow',
            boxWidth: '30%',
            useBootstrap: false,
            buttons: {
                Yes: {
                    text: 'Yes',
                    btnClass: 'btn btn-success',
                    action: function () {
                        deleteData(id);
                    },
                },
                No: {
                    text: 'No',
                    btnClass: 'btn btn-warning',
                    action: function () {
                        return;
                    },
                },
            },
        });
    }

    function deleteData(id) {
        $.ajax({
            type: "POST",
            url: '@Url.Action("DeleteData", "Helpers")',
            data: { id: id },
            success: function (response) {
                if (response) {
                    msgPopup("success", "Data Deleted Successfully");
                    GetData();
                } else {
                    msgPopup("error", "Error! Please Try Again");
                }
            },
            error: function (response) {

            }
        });
    }

    function GetCityDetails() {
        let username = localStorage.getItem('username');
        $.ajax({
            url: '/Configuration/CityDetails',
            type: 'GET',
            dataType: 'json',
            data: { username: username },
            success: function (response) {
                $('#customAdreesLine1').text(response.officeAddress);
                $('#cutomMobileNumbers').text(response.mobileNumbers);
                $('#customEmailAddress').text(response.email);
            },
            error: function (xhr, status, error) {
                console.error(xhr.responseText);
            }
        });
    }
</script>

