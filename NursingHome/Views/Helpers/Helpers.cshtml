<div class="col-12 container-fluid">
    <table id="tblHelpers" class="display table-bordered" style="width:100%">
        <thead>
            <tr>
                <th>Candidate Name</th>
                <th>Permanent Address</th>
                <th>LanguagesKnown</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
        </tbody>
    </table>
