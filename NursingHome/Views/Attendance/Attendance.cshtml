<div class="container-fluid">
    <div class="row">
        <div class="col-md-12 text-right mb-3">
            <button type="button" class="btn btn-success" onclick="ClearAttendenceModalData()" data-toggle="modal" data-target="#AddAttendanceModal">
                Add Attendance
            </button>
        </div>
    </div>

    <!-- Modal for Creating and Editing Attendance -->
    <div class="modal fade" id="AddAttendanceModal" tabindex="-1" role="dialog" aria-labelledby="AttendanceModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="AttendanceModalLabel">Attendance Form</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <form id="attendanceForm" novalidate>
                        <div class="form-group">
                            <label ClearAttendenceClass for="HelperName">Select Helper</label>
                            <select class="form-select ClearAttendenceClass" id="HelperNameDDL" required></select>
                            <div class="invalid-feedback ClearAttendenceClass">Please select the Helper</div>
                        </div>

                        <div class="form-group">
                            <label for="PatientName">Select Patient</label>
                            <select class="form-select ClearAttendenceClass " id="PatientNameDDL" required></select>
                            <div class="invalid-feedback ClearAttendenceClass">Please select the Patient</div>
                        </div>

                        <div class="form-group">
                            <label for="AttendanceDate">Select Date</label>
                            <input type="datetime-local" class="form-control ClearAttendenceClass" id="AttendanceDate" required>
                            <div class="invalid-feedback ClearAttendenceClass">Please select the date</div>
                        </div>

                        <div class="form-group">
                            <label for="TotalHours">Total Work Hours</label>
                            <input type="text" class="form-control ClearAttendenceClass" id="TotalHours">
                        </div>

                        <div class="form-group">
                            <label for="Description">Enter Description</label>
                            <textarea class="form-control ClearAttendenceClass" id="Description" rows="4"></textarea>
                        </div>

                        <input type="hidden" class="ClearAttendenceClass" id="AttendanceId">
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" onclick="AddandEditAttendence()" id="SaveAttendanceData">Save</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Attendance Table -->
    <div class="row mt-4">
        <div class="col-md-12">
            <table id="tableAttendance" class="table table-bordered table-hover">
                <thead class="thead-light">
                    <tr>
                        <th>Helper Name</th>
                        <th>Patient Name</th>
                        <th>Date</th>
                        <th>Total Hours</th>
                        <th>Description</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        var table = $('#tableAttendance').DataTable();
        GetAttendanceData();
        HelpersDropDownList();
        PatientDropDownList();

        

          
        

        $('#tableAttendance').on('click', '.btn-edit', function () {
            var fullData = JSON.parse($(this).attr('data-full-data'));
            BindAttendanceData(fullData);
        });

        $('#tableAttendance').on('click', '.btn-delete', function () {
            var ID = $(this).attr('data-id');
            debugger
            confirmDelete(ID);
        });
       
    });
    function AddandEditAttendence() {
        var helperName = $('#HelperNameDDL').val();
        var patientName = $('#PatientNameDDL').val();
        var attendanceDate = $('#AttendanceDate').val();
        var totalHours = $('#TotalHours').val();
        var description = $('#Description').val();
        var attendanceId = $('#AttendanceId').val();
        debugger
        
        $.ajax({
            url: '/Attendance/AddandUpdateAttendance',
            type: 'POST',
            data: {
                fkHelperId: helperName,
                fkNursingId: patientName,
                Date: attendanceDate,
                Time: totalHours,
                Description: description,
                Id: attendanceId
            },
            success: function (response) {
                if (response) {
                    GetAttendanceData();

                    if (attendanceId == null || attendanceId == 0) {
                            alert('Successdata added succesfully');
                        }
                        else
                        {
                           alert('Successdata Updated succesfully');
                        }

                    
                    $('#AddAttendanceModal').modal('hide');
                }
            },
            error: function (xhr, status, error) {
                alert('An error occurred: ' + error);
            }
        });
    }

    function confirmDelete(id) {
        $.confirm({
            title: 'Confirm',
            content: 'Are you sure you want to delete this record?',
            buttons: {
                Yes: {
                    btnClass: 'btn btn-success',
                    action: function () {
                        deleteAttendance(id);
                    }
                },
                No: {
                    btnClass: 'btn btn-warning',
                    action: function () { }
                }
            }
        });
    }

    function BindAttendanceData(data) {
        debugger
        $('#HelperNameDDL').val(data.fkHelperId);
        $('#PatientNameDDL').val(data.fknursing);
        $('#AttendanceDate').val(data.attendanceDate);
        $('#TotalHours').val(data.time);
        $('#Description').val(data.description);
        $('#AttendanceId').val(data.attendanceId);
        $('#AddAttendanceModal').modal('show');
    }

    function deleteAttendance(id) {
        $.ajax({
            type: 'POST',
            url: '/Attendance/DeleteAttendence',
            data: { id: id },
            success: function (response) {
                GetAttendanceData();
                alert('data deleted Successfully');
            },
            error: function (response) {
                console.error(response);
                alert(' error occured  deleting Data');
            }
        });
    }

    function GetAttendanceData() {
        var table = $('#tableAttendance').DataTable();

        $.ajax({
            type: 'POST',
            url: '/Attendance/GetAttendanceData',
            success: function (response) {
                table.clear(); // Clear the table before adding new data
                debugger
                response.data.forEach(function (item) {
                    table.row.add([
                        item.helperName,
                        item.patientName,
                        item.attendanceDate,
                        item.time,
                        
                        item.description,

                        // HTML for edit and delete icons
                        `<div class="text-center">
                            <i class="fa fa-edit me-4 btn-edit" style="color:green" data-full-data='${JSON.stringify(item).replace(/'/g, "&#39;")}'></i>
                                <i class="fa fa-trash btn-delete" style="color:red" data-id="${item.attendanceId}"></i>
                            </div>`
                    ]).draw(); // Redraw the table with new data
                });
            },
            error: function (xhr, status, error) {
                alert('An error occurred: ' + error);
            }
        });
    }
   



    function PatientDropDownList() {
        $.ajax({
            url: '/Attendance/GetPatientDetails',
            type: 'GET',
            success: function (response) {
                const PatientDropDownDDl = $('#PatientNameDDL');
                PatientDropDownDDl.empty();

                const $defaultOption = $('<option>', {
                    value: '',
                    text: 'Select Patient',
                    selected: true
                });
                PatientDropDownDDl.append($defaultOption);

                // Adjusting to match the actual property names from the response (id and patientName)
                $.each(response.data, function (index, item) {
                    const $option = $('<option>', {
                        value: item.id,            // Changed to lowercase 'id'
                        text: item.patientName     // Changed to lowercase 'patientName'
                    });
                    PatientDropDownDDl.append($option);
                });
            },
            error: function (xhr, status, error) {
                console.error("Error fetching Patient Details:", error);
            }
        });
    }


    function HelpersDropDownList() {
        $.ajax({
            url: '/Attendance/GetHelpers',
            type: 'GET',
            success: function (response) {
                const HelpersDropDownDDL = $('#HelperNameDDL');
                HelpersDropDownDDL.empty();

                const $defaultOption = $('<option>', {
                    value: '',
                    text: 'Select Helper',
                    selected: true
                });
                HelpersDropDownDDL.append($defaultOption);

                // Assuming the properties for helpers follow the same structure
                $.each(response.data, function (index, item) {
                    const $option = $('<option>', {
                        value: item.id,            // Changed to lowercase 'id'
                        text: item.name            // Assuming the property is 'name' for helpers
                    });
                    HelpersDropDownDDL.append($option);
                });
            },
            error: function (xhr, status, error) {
                console.error("Error fetching Helpers Details:", error);
            }
        });
    }
    function ClearAttendenceModalData()
    {
        $('.ClearAttendenceClass').val('')
    }

</script>
