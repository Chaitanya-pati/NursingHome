<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    @if (ViewData["Title"] != "Login" && ViewData["Title"] != "Website")
    {
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
        <link href="~/style/common.css" rel="stylesheet" />

        <!-- Font Awesome -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

        <!-- DataTables CSS -->
        <link rel="stylesheet" href="https://cdn.datatables.net/1.13.1/css/jquery.dataTables.min.css">

        <!-- jQuery Confirm CSS -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jquery-confirm/3.3.4/jquery-confirm.min.css">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-datepicker@1.9.0/dist/css/bootstrap-datepicker.min.css">

        <!-- SweetAlert2 CSS -->
        <link href="~/toastr/sweetalert2.min.css" rel="stylesheet" />

        <!-- jQuery -->
        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

        <!-- jsPDF and AutoTable -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.11/jspdf.plugin.autotable.min.js"></script>

        <!-- Bootstrap DatePicker JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap-datepicker@1.9.0/dist/js/bootstrap-datepicker.min.js"></script>

        <!-- Popper.js -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/2.11.7/umd/popper.min.js"></script>

        <!-- Bootstrap Bundle JS -->
        <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.bundle.min.js"></script>

        <!-- DataTables JS -->
        <script src="https://cdn.datatables.net/1.13.1/js/jquery.dataTables.min.js"></script>

        <!-- Mobile card-label injector — registered HERE so it catches the very first draw -->
        <script>
            $(document).on('draw.dt', function (e, settings) {
                var api = new $.fn.dataTable.Api(settings);
                var headers = $(api.table().header()).find('th').map(function () {
                    return $(this).text().trim();
                }).get();
                $(api.table().body()).find('tr').each(function () {
                    $(this).find('td').each(function (i) {
                        var $td = $(this);
                        if ($td.find('.cell-label').length) return;
                        var label = headers[i] || '';
                        var content = $td.html();
                        $td.html(
                            '<span class="cell-label">' + label + '</span>' +
                            '<span class="cell-value">' + content + '</span>'
                        );
                    });
                });
            });
        </script>

        <!-- jQuery Confirm JS -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-confirm/3.3.4/jquery-confirm.min.js"></script>

        <!-- Moment.js -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>

        <!-- Bootstrap Multiselect JS -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-multiselect/0.9.13/js/bootstrap-multiselect.min.js"></script>

        <!-- HTML2PDF JS -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

        <!-- Custom JS -->
        <script src="~/js/site.js" asp-append-version="true"></script>

        <!-- Additional Custom JS -->
        <script src="~/js/common.js"></script>

        <!-- SweetAlert2 JS -->
        <script src="~/toastr/sweetalert2.min.js"></script>

        <style>
            /* ===================================================
               FIXED TOP HEADER
               =================================================== */
            .app-header {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                height: 50px;
                z-index: 200;
                background-color: #f7f6fa;
                border-bottom: 1px solid #c5bddb;
                display: flex;
                align-items: center;
                padding: 0 12px;
            }

            /* ===================================================
               MOBILE HAMBURGER BUTTON (inside fixed header)
               =================================================== */
            .mobile-menu-toggle {
                display: none;
                background: #6750a4;
                border: none;
                color: white;
                padding: 7px 11px;
                border-radius: 5px;
                cursor: pointer;
                font-size: 18px;
                line-height: 1;
                flex-shrink: 0;
            }

            .mobile-menu-toggle:hover {
                background: #5440a0;
            }

            /* ===================================================
               SIDEBAR OVERLAY
               =================================================== */
            .sidebar-overlay {
                display: none;
                position: fixed;
                top: 50px;
                left: 0;
                right: 0;
                bottom: 0;
                background: rgba(0, 0, 0, 0.5);
                z-index: 98;
            }

            .sidebar-overlay.active {
                display: block;
            }

            /* ===================================================
               SIDEBAR — starts below the fixed header
               =================================================== */
            .sidebar {
                position: fixed;
                left: 0;
                top: 50px;
                height: calc(100% - 50px);
                width: 78px;
                background: #11101d;
                padding: 6px 14px;
                z-index: 99;
                transition: all 0.5s ease;
                overflow-x: hidden;
                overflow-y: auto;
            }

            .sidebar.open {
                width: 250px;
            }

            .sidebar .logo-details {
                height: 60px;
                display: flex;
                align-items: center;
                position: relative;
            }

            .sidebar .logo-details .icon {
                opacity: 0;
                transition: all 0.5s ease;
            }

            .sidebar .logo-details .logo_name {
                color: #fff;
                font-size: 20px;
                font-weight: 600;
                opacity: 0;
                transition: all 0.5s ease;
                white-space: nowrap;
            }

            .sidebar.open .logo-details .icon,
            .sidebar.open .logo-details .logo_name {
                opacity: 1;
            }

            .sidebar .logo-details #btn {
                position: absolute;
                top: 50%;
                right: 0;
                transform: translateY(-50%);
                font-size: 23px;
                text-align: center;
                cursor: pointer;
                transition: all 0.5s ease;
            }

            .sidebar.open .logo-details #btn {
                text-align: right;
            }

            .sidebar i {
                color: #fff;
                height: 60px;
                min-width: 50px;
                font-size: 28px;
                text-align: center;
                line-height: 60px;
            }

            .sidebar .nav-list {
                margin-top: 20px;
                height: 100%;
                padding-bottom: 60px;
            }

            .sidebar li {
                position: relative;
                margin: 8px 0;
                list-style: none;
            }

            .sidebar li .tooltip {
                position: absolute;
                top: -20px;
                left: calc(100% + 15px);
                z-index: 3;
                background: #fff;
                box-shadow: 0 5px 10px rgba(0, 0, 0, 0.3);
                padding: 6px 12px;
                border-radius: 4px;
                font-size: 15px;
                font-weight: 400;
                opacity: 0;
                white-space: nowrap;
                pointer-events: none;
                transition: 0s;
            }

            .sidebar li:hover .tooltip {
                opacity: 1;
                pointer-events: auto;
                transition: all 0.4s ease;
                top: 50%;
                transform: translateY(-50%);
            }

            .sidebar.open li .tooltip {
                display: none;
            }

            .sidebar input {
                font-size: 15px;
                color: #fff;
                font-weight: 400;
                outline: none;
                height: 50px;
                width: 50px;
                border: none;
                border-radius: 12px;
                transition: all 0.5s ease;
                background: #1d1b31;
            }

            .sidebar.open input {
                padding: 0 20px 0 50px;
                width: 100%;
            }

            .sidebar .bx-search {
                position: absolute;
                top: 50%;
                left: 0;
                transform: translateY(-50%);
                font-size: 22px;
                background: #1d1b31;
                color: #fff;
            }

            .sidebar.open .bx-search:hover {
                background: #1d1b31;
                color: #fff;
            }

            .sidebar .bx-search:hover {
                background: #fff;
                color: #11101d;
            }

            .sidebar li a {
                display: flex;
                height: 100%;
                width: 100%;
                border-radius: 12px;
                align-items: center;
                text-decoration: none;
                transition: all 0.4s ease;
                background: #11101d;
            }

            .sidebar li a:hover {
                background: #fff;
            }

            .sidebar li a .links_name {
                color: #fff;
                font-size: 15px;
                font-weight: 400;
                white-space: nowrap;
                opacity: 0;
                pointer-events: none;
                transition: 0.4s;
            }

            .sidebar.open li a .links_name {
                opacity: 1;
                pointer-events: auto;
            }

            .sidebar li a:hover .links_name,
            .sidebar li a:hover i {
                transition: all 0.5s ease;
                color: #11101d;
            }

            .sidebar li i {
                height: 50px;
                line-height: 50px;
                font-size: 18px;
                border-radius: 12px;
            }

            .sidebar li.profile {
                position: absolute;
                height: 60px;
                width: 78px;
                left: 0;
                bottom: 0;
                padding: 10px 14px;
                background: #1d1b31;
                transition: all 0.5s ease;
                overflow: hidden;
            }

            .sidebar.open li.profile {
                width: 250px;
            }

            .sidebar li .profile-details {
                display: flex;
                align-items: center;
                flex-wrap: nowrap;
            }

            .sidebar li.profile .name,
            .sidebar li.profile .job {
                font-size: 15px;
                font-weight: 400;
                color: #fff;
                white-space: nowrap;
            }

            .sidebar li.profile .job {
                font-size: 12px;
            }

            .sidebar .profile #log_out {
                position: absolute;
                top: 50%;
                right: 0;
                transform: translateY(-50%);
                background: #1d1b31;
                width: 100%;
                height: 60px;
                line-height: 60px;
                border-radius: 0px;
                transition: all 0.5s ease;
            }

            .sidebar.open .profile #log_out {
                width: 50px;
                background: none;
            }

            /* ===================================================
               MAIN CONTENT AREA
               =================================================== */
            .home-section {
                margin-left: 78px;
                margin-top: 50px;
                min-height: calc(100vh - 50px);
                transition: margin-left 0.5s ease;
                background-color: #f7f7fa;
            }

            .sidebar.open ~ .home-section {
                margin-left: 250px;
            }

            /* ===================================================
               TABLET (769px – 1024px)
               =================================================== */
            @@media screen and (min-width: 769px) and (max-width: 1024px) {
                .home-section {
                    margin-left: 78px;
                }
            }

            /* ===================================================
               MOBILE (≤ 768px)
               =================================================== */
            @@media screen and (max-width: 768px) {
                .mobile-menu-toggle {
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }

                .sidebar {
                    left: -250px;
                    width: 250px;
                    top: 50px;
                    height: calc(100% - 50px);
                }

                .sidebar.mobile-open {
                    left: 0;
                }

                .sidebar .logo-details .icon,
                .sidebar .logo-details .logo_name {
                    opacity: 1;
                }

                .sidebar li a .links_name {
                    opacity: 1;
                    pointer-events: auto;
                }

                .sidebar .logo-details #btn {
                    display: none;
                }

                .sidebar li.profile {
                    width: 250px;
                }

                .home-section {
                    margin-left: 0 !important;
                }
            }
        </style>
    }
</head>
<body style="background-color:#f7f7fa">
    @if (ViewData["Title"] != "Login" && ViewData["Title"] != "Website")
    {
        <header class="app-header">
            <button class="mobile-menu-toggle" id="mobileMenuBtn">
                <i class="fa-solid fa-bars"></i>
            </button>
        </header>
        <div class="sidebar-overlay" id="sidebarOverlay"></div>
        <div class="sidebar">
            <div class="logo-details">
                <i class="fa-solid fa-notes-medical icon"></i>
                <div class="logo_name">VEDHANTH Home Nursing</div>
                <i class="fa-solid fa-bars" id="btn"> </i>
            </div>
            <ul class="nav-list">
                <li>
                    <a class="" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="fa-solid fa-house"></i>
                        <span class="links_name">Home</span>
                    </a>
                    <span class="tooltip">Home</span>
                </li>
                <li>
                    <a class="" asp-area="" asp-controller="OldAge" asp-action="OldAge">
                        <i class="fa-solid fa-person-walking-with-cane"></i>
                        <span class="links_name">Old Age</span>
                    </a>
                    <span class="tooltip">Old Age</span>
                </li>
                <li>
                    <a class="" asp-area="" asp-controller="NursingHome" asp-action="NursingHome">
                        <i class="fa-solid fa-hand-holding-medical"></i>
                        <span class="links_name">Home Nursing</span>
                    </a>
                    <span class="tooltip">Home Nursing</span>
                </li>
                <li>
                    <a class="" asp-area="" asp-controller="Helpers" asp-action="Helpers">
                        <i class="fa-solid fa-user-doctor"></i>
                        <span class="links_name">Helpers</span>
                    </a>
                    <span class="tooltip">Helpers</span>
                </li>
                <li>
                    <a class="" asp-area="" asp-controller="CashMemo" asp-action="CashMemo">
                        <i class="fa-solid fa-money-check-dollar"></i>
                        <span class="links_name">Cash Memo</span>
                    </a>
                    <span class="tooltip">Cash Memo</span>
                </li>
                <li>
                    <a class="" asp-area="" asp-controller="Attendance" asp-action="Attendance">
                        <i class="fa-solid fa-users"></i>
                        <span class="links_name">Attendance</span>
                    </a>
                    <span class="tooltip">Attendance</span>
                </li>
                <li>
                    <a class="" asp-area="" asp-controller="SalarySlip" asp-action="SalarySlip">
                        <i class="fa-solid fa-file-invoice-dollar"></i>
                        <span class="links_name">SalarySlip</span>
                    </a>
                    <span class="tooltip">SalarySlip</span>
                </li>
                <li class="AuthorizedContent" hidden>
                    <a class="" asp-area="" asp-controller="Home" asp-action="Reports">
                        <i class="fa-solid fa-chart-column"></i>
                        <span class="links_name">Reports</span>
                    </a>
                    <span class="tooltip">Reports</span>
                </li>
                <li class="AuthorizedContent" hidden>
                    <a class="" asp-area="" asp-controller="Configuration" asp-action="Configuration">
                        <i class="fa-solid fa-gear"></i>
                        <span class="links_name">Configuration</span>
                    </a>
                    <span class="tooltip">Configuration</span>
                </li>
                <li class="AuthorizedContent" hidden>
                    <a class="" asp-area="" asp-controller="Users" asp-action="Users">
                        <i class="fa-solid fa-user-group"></i>
                        <span class="links_name">User</span>
                    </a>
                    <span class="tooltip">Users</span>
                </li>
                <li class="profile">
                    <div class="profile-details">
                        <i class="fa-solid fa-right-from-bracket"></i>
                        <div class="name_job">
                            <div class="name">Logout</div>
                        </div>
                    </div>
                    <a class="" asp-area="" asp-controller="Users" asp-action="Login">
                        <i class="fa-solid fa-right-from-bracket" id="log_out"></i>
                    </a>
                </li>
            </ul>
        </div>
    }
    <div class="home-section">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
    @if (ViewData["Title"] != "Login" && ViewData["Title"] != "Website")
    {
        <script>
            let sidebar = document.querySelector(".sidebar");
            let closeBtn = document.querySelector("#btn");
            let mobileMenuBtn = document.querySelector("#mobileMenuBtn");
            let sidebarOverlay = document.querySelector("#sidebarOverlay");

            if (closeBtn) {
                closeBtn.addEventListener("click", () => {
                    sidebar.classList.toggle("open");
                });
            }

            if (mobileMenuBtn) {
                mobileMenuBtn.addEventListener("click", () => {
                    sidebar.classList.toggle("mobile-open");
                    sidebarOverlay.classList.toggle("active");
                });
            }

            if (sidebarOverlay) {
                sidebarOverlay.addEventListener("click", () => {
                    sidebar.classList.remove("mobile-open");
                    sidebarOverlay.classList.remove("active");
                });
            }

            let id = localStorage.getItem('userID');
            if (id == null) {
                window.location.href = '/Users/Login';
            } else {
                $.ajax({
                    type: "GET",
                    url: '/Users/GetUserDataById',
                    data: { id: id },
                    success: function (response) {
                        if (response != null) {
                            localStorage.setItem('userRole', response.roles);
                            localStorage.setItem('username', response.userName);
                            if (response.roles == 'admin') {
                                $('.AuthorizedContent').each((index, element) => {
                                    $(element).prop('hidden', false);
                                });
                            }
                        }
                    },
                    error: function (response) { }
                });
            }
        </script>
    }
</body>
</html>
