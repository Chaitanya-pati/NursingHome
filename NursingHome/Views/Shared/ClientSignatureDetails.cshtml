@using Azure.Core
@model dynamic
@{
    ViewData["Title"] = "Client Signature Details";
    Layout = null;
    bool isHomeNursing = Model.GetType().GetProperty("fkHelperId") != null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 40px 20px;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        h2 {
            color: white;
            text-align: center;
            margin-bottom: 30px;
            font-weight: 600;
            font-size: 32px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
        }

        .table-container {
            max-width: 1000px;
            margin: 0 auto;
            background: white;
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        }

        .table {
            margin-bottom: 0;
        }

        .table-bordered {
            border: none;
        }

            .table-bordered td {
                border: none;
                border-bottom: 1px solid #f1f3f5;
                padding: 16px 20px;
                vertical-align: middle;
            }

            .table-bordered tr:last-child td {
                border-bottom: none;
            }

            .table-bordered td:first-child {
                font-weight: 600;
                color: #495057;
                width: 220px;
                background: #f8f9fa;
            }

            .table-bordered td:last-child {
                color: #6c757d;
            }

        .signatureContainer {
            border: 2px dashed #dee2e6 !important;
            border-radius: 10px;
            cursor: crosshair;
            width: 100% !important;
            max-width: 500px !important;
            height: 200px !important;
            background: white;
            display: block;
            margin-bottom: 15px;
            touch-action: none;
        }

        .btn {
            padding: 10px 25px;
            border-radius: 8px;
            font-weight: 600;
            border: none;
            transition: all 0.3s ease;
            margin-right: 10px;
        }

        .btn-warning {
            background: #6c757d;
            color: white;
        }

            .btn-warning:hover {
                background: #5a6268;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(108, 117, 125, 0.3);
                color: white;
            }

        .btn-success {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

            .btn-success:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
                color: white;
            }

        img {
            border: 2px solid #dee2e6;
            border-radius: 10px;
            padding: 10px;
            background: white;
            width: 200px !important;
            height: 100px !important;
        }

        @@media (max-width: 768px) {
            body

        {
            padding: 20px 10px;
        }

        .table-container {
            padding: 20px;
        }

        .table-bordered td:first-child {
            width: 150px;
            font-size: 14px;
        }

        .table-bordered td {
            padding: 12px 15px;
            font-size: 14px;
        }

        .signatureContainer {
            max-width: 100% !important;
            height: 180px !important;
        }

        .btn {
            margin-bottom: 10px;
            margin-right: 5px;
            padding: 12px 20px;
        }

        h2 {
            font-size: 24px;
        }

        img {
            width: 150px !important;
            height: 75px !important;
        }

        }

        @@media (max-width: 480px) {
            body

        {
            padding: 15px 5px;
        }

        .table-container {
            padding: 15px;
        }

        .table-bordered td:first-child {
            width: 120px;
            font-size: 13px;
            padding: 10px 8px;
        }

        .table-bordered td {
            padding: 10px 8px;
            font-size: 13px;
        }

        .signatureContainer {
            height: 160px !important;
        }

        .btn {
            width: calc(50% - 5px);
            margin-bottom: 10px;
            padding: 12px 15px;
            font-size: 14px;
        }

        h2 {
            font-size: 20px;
        }

        img {
            width: 120px !important;
            height: 60px !important;
        }

        }

       
        .terms-box {
            margin-top: 20px;
            font-size: 14px;
            line-height: 1.6;
        }

        .terms-title {
            font-weight: bold;
            font-size: 16px;
            margin-bottom: 10px;
        }

        .terms-list {
            padding-left: 20px;
        }

            .terms-list li {
                margin-bottom: 8px;
            }

        .declaration {
            margin-top: 15px;
            font-weight: 500;
        }
   
    </style>
</head>
<body>
    <h2>Client Signature Details</h2>
    <div class="table-container">
        <table class="table table-bordered">
            <tr><td>Patient Name</td><td>@Model.PatientName</td></tr>
            <tr><td>Address</td><td>@Model.Address</td></tr>
            <tr><td>Age</td><td>@Model.Age</td></tr>
            <tr><td>Condition</td><td>@Model.Condition</td></tr>
            <tr><td>Customer Name</td><td>@Model.CustomerName</td></tr>
            <tr><td>Mobile No</td><td>@Model.MobileNo</td></tr>
            <tr><td>Types of Services</td><td>@Model.TypesofServices</td></tr>
            <tr><td>Registration Charges</td><td>@Model.RegistrationCharges</td></tr>
            <tr><td>Monthly Payment</td><td>@Model.MonthlyPayment</td></tr>
            <tr><td>Period From</td><td>@Model.PeriodFrom</td></tr>
            <tr><td>Period To</td><td>@Model.PeriodTo</td></tr>
            <tr><td>Payment Status</td><td>@Model.PaymentStatus</td></tr>
            <tr><td>Created Date</td><td>@Model.CreatedDate</td></tr>
            <tr><td>Updated Date</td><td>@Model.UpdatedDate</td></tr>
            <tr><td>SUser</td><td>@Model.SUser</td></tr>
            <!-- Terms and Conditions Section -->
            <tr>
                <td colspan="2">
                    <div class="terms-box">
                        @if (isHomeNursing)
                        {
                            <div class="terms-title">VEDHANTH Home Nursing Services – Terms and Conditions</div>
                            <ol class="terms-list">
                                <li>VEDHANTH Home Nursing Services requires a one-time registration with a non-refundable deposit.</li>
                                <li>VEDHANTH Home Nursing Services reserves the right to take action for any violation.</li>
                                <li>If services are canceled directly with staff without informing us, action will be taken.</li>
                                <li>Replacement nurse will be provided in case of emergency leave.</li>
                                <li>If staff feels unsafe or complaints arise, service will be stopped.</li>
                                <li>Nurse will only provide nursing services, not household work.</li>
                                <li>Extra work is between family and nurse only.</li>
                                <li>Family must ensure safety of valuables.</li>
                                <li>Do not share banking or personal passwords.</li>
                                <li>Continuing service with same staff without consent is not allowed.</li>
                                <li>We are responsible only for nursing service.</li>
                                <li>Death within 15 days – advance is non-refundable.</li>
                                <li>Staff must be treated respectfully.</li>
                                <li>Staff will not do household work.</li>
                                <li>Replacement will be provided for leave.</li>
                            </ol>

                            <div class="terms-title">Declaration</div>
                            <div class="declaration">
                                I hereby read and understood all the above terms and conditions and agree to sign up with
                                VEDHANTH Home Care for my service requirement.
                            </div>
                        }
                        else if (!isHomeNursing)
                        {
                            <div class="terms-title">Terms and Conditions for Client</div>
                            <ol class="terms-list">
                                <li>We provide attender, nursing staff, and emergency doctor visit.</li>
                                <li>Three times food with tea/coffee (menu changes daily).</li>
                                <li>Outside food is not allowed.</li>
                                <li>Personal medicines and supplies are not provided.</li>
                                <li>Unused advance will be refunded on early discharge.</li>
                                <li>In case of death, advance is non-refundable.</li>
                            </ol>

                            <div class="terms-title">Declaration</div>
                            <div class="declaration">
                                I hereby read and understood all the above terms and conditions and agree to sign up with
                                VEDHANTH Home Care for my service requirement.
                            </div>
                        }
                        else
                        {
                            <p>No specific terms and conditions available for this service.</p>
                        }
                    </div>
                </td>
            </tr>

            <tr>
                <td>Client Signature</td>
                <td>
                    <canvas id="clientSignature" class="signatureContainer" style="border:1px solid #ccc;width:400px;height:200px;"></canvas>
                    <br />
                    <button id="clearSignature" class="btn btn-warning">Clear</button>
                    <button id="submitSignature" class="btn btn-success">Submit Signature</button>
                </td>
            </tr>
            <tr>
                <td>Authorized Signature</td>
                <td>
                    <img src="data:image/png;base64,@Model.authorizedSign" style="width:200px;height:100px;" />
                </td>
            </tr>
        </table>
       
    </div>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/js/common.js"></script>
    <script>
        const canvasSign = document.getElementById('clientSignature');
        const context = canvasSign.getContext('2d');

        document.getElementById('clearSignature').onclick = function() {
            context.clearRect(0, 0, canvasSign.width, canvasSign.height);
        };

        document.getElementById('submitSignature').onclick = function() {
            const signatureData = document.getElementById('clientSignature').toDataURL("image/png").replace(/^data:image\/(png|jpg);base64,/, "");
            const urlParams = new URLSearchParams(window.location.search);
            const id = urlParams.get('id');
            let postUrl = window.location.pathname.startsWith('/OldAge') ? '/OldAge/UpdateClientSignature' : '/NursingHome/UpdateClientSignature';
            if(postUrl && id) {
                $.ajax({
                    type: 'POST',
                    url: postUrl,
                    data: { id: id, signature: signatureData },
                    success: function(response) {
                        alert('Signature submitted successfully!');
                    },
                    error: function() {
                        alert('Error submitting signature.');
                    }
                });
            } else {
                alert('Invalid link or missing parameters.');
            }
        };
    </script>
</body>
</html>