                                        </div>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td><label for="patientName">Patient Name:</label></td>
                                <td><input type="text" class="form-control  OldAgeIpfields requiredfield" id="patientName"></td>
                            </tr>
                            <tr>
                                <td><label for="address">Address:</label></td>
                                <td><input type="text" class="form-control  OldAgeIpfields" id="address"></td>
                            </tr>
                            <tr>
                                <td><label for="patientAge">Patient Age:</label></td>
                                <td><input type="text" class="form-control  OldAgeIpfields" id="patientAge"></td>
                            </tr>
                            <tr>
                                <td><label for="patientCondition">Patient Condition:</label></td>
                                <td><input type="text" class="form-control  OldAgeIpfields" id="patientCondition"></td>
                            </tr>
                            <tr>
                                <td><label for="customerName">Customer Name:</label></td>
                                <td><input type="text" class="form-control  OldAgeIpfields" id="customerName"></td>
                            </tr>
                            <tr>
                                <td><label for="mobileNo">Mobile No:</label></td>
                                <td><input type="text" class="form-control  OldAgeIpfields" id="mobileNo"></td>
                            </tr>
                            <tr>
                                <td><label for="typesOfService">Types of Service:</label></td>
                                <td><input type="text" class="form-control  OldAgeIpfields" id="typesOfService"></td>
                            </tr>
                            <tr>
                                <td><label for="idProof">ID Proof:</label></td>
                                <td>
                                    <div class="row col-12">
                                        <div class="col-10">
                                            <input type="file" class="form-control" id="idProof" accept="image/jpeg,image/jpg,image/png,application/pdf">
                                            <div id="idProofStatus" class="mt-1 small" style="display:none;"></div>
                                        </div>
                                        <div class="col-2 contentEnd">
                                            <i id="downloadIdProof" class="fa-solid fa-download fa-lg  mt-3 "></i>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td><label for="registrationCharges">Registration Charges:</label></td>
                                <td><input type="text" class="form-control  OldAgeIpfields" id="registrationCharges"></td>
                            </tr>
                            <tr>
                                <td><label for="monthlyPayment">Monthly Payment Rs:</label></td>
                                <td><input type="text" class="form-control  OldAgeIpfields" id="monthlyPayment"></td>
                            </tr>
                            <tr>
                                <td><label for="periodFrom">Period From:</label></td>
                                <td><input type="date" class="form-control  OldAgeIpfields" id="periodFrom"></td>
                            </tr>
                            <tr>
                                <td><label for="periodTo">To:</label></td>
                                <td><input type="date" class="form-control  OldAgeIpfields" id="periodTo"></td>
                            </tr>
                            <tr>
                                <td colspan="2">
                                    <div>
                                        <b>Terms and Conditions for Client:</b>
                                        <div style="display: flex; flex-direction: column;">
                                            <div style="display: flex; margin-top: 10px;">
                                                <div style="width: 50px; font-weight: bold; text-align: center;">1.</div>
                                                <div style="flex: 1; text-align: left;">We give with patients attender and nursing staff with emergency doctor visit.</div>
                                            </div>

                                            <div style="display: flex; margin-top: 10px;">
                                                <div style="width: 50px; font-weight: bold; text-align: center;">2.</div>
                                                <div style="flex: 1; text-align: left;">Three times food and tea, coffee (daily changes of food).</div>
                                            </div>

                                            <div style="display: flex; margin-top: 10px;">
                                                <div style="width: 50px; font-weight: bold, text-align: center;">3.</div>
                                                <div style="flex: 1; text-align: left;">We don't allow outside food and we don't provide any event foods for patients.</div>
                                            </div>

                                            <div style="display: flex; margin-top: 10px;">
                                                <div style="width: 50px; font-weight: bold; text-align: center;">4.</div>
                                                <div style="flex: 1; text-align: left;">We don't gives any personal medication to patients (BP, SUGAR TABLETS DIAPER HAND GLOVES UNDER PAD/PATIENTS AU THINGS).</div>
                                            </div>

                                            <div style="display: flex; margin-top: 10px;">
                                                <div style="width: 50px; font-weight: bold; text-align: center;">5.</div>
                                                <div style="flex: 1; text-align: left;">If the patient's discharge days are fewer than the advance payment balance, the remaining amount should be returned to the client.</div>
                                            </div>

                                            <div style="display: flex; margin-top: 10px;">
                                                <div style="width: 50px; font-weight: bold; text-align: center;">6.</div>
                                                <div style="flex: 1; text-align: left;">In case patient death non refund advance amount.</div>
                                            </div>
                                        </div>

                                        <b> Declaration</b></br>
                                        <div style="display: flex; margin-top: 5px;margin-bottom:20px">
                                            <div style="width: 20px; font-weight: bold; text-align: center;"> </div>
                                            <div style="flex: 1; text-align: left;">
                                                I hereby read, I heard all the above terms and conditions and agree to sign up with VEDHANTH Home Care for my service requirement.
                                            </div>
                                        </div>
                                        @*<div class="row">

                                        <span class="col-4">Signature of the Client</span>
                                        <span class="col-4"></span>
                                        <span class="col-4 contentEnd">Authorised Signatory</span>
                                        </div>*@
                                        <div class="signature-section row ml-2">
                                            <div class="signature-box col-4 ">
                                                <canvas id="clientSignature" class="signatureContainer"></canvas>
                                                <img id="clientSignatureImage" class="signatureContainerImage" hidden />
                                                <div class="row">
                                                    <div class="col-10">
                                                        <p>Signature of the Client &nbsp;&nbsp;&nbsp;   <i class="fa-solid fa-arrows-rotate refreshSign" onclick="clearSignature('clientSignature')"></i></p>
                                                    </div>
                                                    <div class="col-2">
                                                    </div>
                                                </div>

                                            </div>
                                            <div class="col-4"></div>
                                            <div class="signature-box col-4">
                                                <canvas id="authorizedSignature" class="signatureContainer"></canvas>
                                                <img id="authorizedSignatureImage" class="signatureContainerImage" hidden />
                                                <div class="row">
                                                    <p>Authorised Signatory  &nbsp;&nbsp;&nbsp;<i class="fa-solid fa-arrows-rotate refreshSign" onclick="clearSignature('authorizedSignature')"></i></p>
                                                </div>

                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="HidePopup('oldAgePopup')" data-dismiss="modal">Close</button>
                <button type="button" class="btn btn-success" onclick="OpenQRPopup()">Pay</button>
                <button type="button" class="btn btn-success" onclick="AddOldAge()">Save</button>
                <button id="downloadRegistrationForm" class="btn btn-info">Download PDF</button>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid mb-2 mt-2 page-add-btn">
    <button type="button" class="customBtn" onclick="verifyFace()">
        <i class="fa fa-add me-1"></i> Add
    </button>
</div>
<div class="col-md-12 container-fluid">
    <table id="tblOldAge" class="display table-bordered rct-table" style="width:100%">
        <thead>
            <tr>
                <th>Patient Name</th>
                <th>Admission Date</th>
                <th>Period From</th>
                <th>Period To</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
        </tbody>
    </table>
    @Html.Partial("~/Partialviews/_VerifyFace.cshtml")
</div>
<style>
    .loader {
        display: none;
        position: fixed;
        z-index: 9999;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }

        .loader .spinner {
            border: 8px solid #f3f3f3;
            border-top: 8px solid #3498db;
            border-radius: 50%;
            width: 60px;
            height: 60px;
            animation: spin 1s linear infinite;
        }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    /* Column labels for mobile card view — layout handled by site.css (.rct-table) */
    @@media (max-width: 767px) {
        #tblOldAge td:nth-child(1)::before { content: "Patient Name"; }
        #tblOldAge td:nth-child(2)::before { content: "Admission Date"; }
        #tblOldAge td:nth-child(3)::before { content: "Period From"; }
        #tblOldAge td:nth-child(4)::before { content: "Period To"; }
    }

    /* Modal responsiveness */
    @@media screen and (max-width: 768px) {
        .custom-modal-dialog {
            width: 95% !important;
            margin: 1rem auto !important;
        }

        .modal-body {
            padding: 15px;
        }

        .modal-body table tr td:first-child {
            display: block;
            width: 100%;
            font-weight: bold;
            padding-bottom: 5px;
        }

        .modal-body table tr td:last-child {
            display: block;
            width: 100%;
            padding-top: 5px;
        }

        .signature-section {
            flex-direction: column !important;
        }

        .signature-box {
            width: 100% !important;
            margin-bottom: 20px;
        }

        .modal-footer {
            flex-wrap: wrap;
            gap: 5px;
        }

        .modal-footer button {
            flex: 1 1 45%;
            margin: 2px;
        }
    }

    @@media screen and (max-width: 576px) {
        .container-fluid {
            padding: 10px;
        }

        .customBtn {
            width: 100%;
            margin-bottom: 10px;
        }

        .modal-footer button {
            flex: 1 1 100%;
        }
    }
</style>
<div id="oldAgeLoader" class="loader"><div class="spinner"></div></div>
<script>

        var OldAgeIdProof;
        $(document).ready(function () {

            $('#tblOldAge').on('click', '.btn-edit', function () {
                var fullData = JSON.parse($(this).attr('data-full-data'));
                BindData(fullData);
            });
            $('#tblOldAge').on('click', '.btn-delete', function () {
                var ID = JSON.parse($(this).attr('dataId'));
                confirmDelete(ID);
            });
            $('#tblOldAge').on('click', '.btn-sign-link', function () {
                var itemId = $(this).attr('data-id');
                var baseUrl = '@Configuration["ClientSignatureBaseUrl"]';
                var link = baseUrl + '/OldAge/ClientSignature?id=' + itemId;
                $('#clientSignatureLink').val(link);
                $('#clientSignatureLinkContainer').show();
                $('html, body').animate({ scrollTop: $('#clientSignatureLinkContainer').offset().top }, 400);
            });
            $('#tblOldAgePayment').on('click', '.btn-edit', function () {
                var fullData = JSON.parse($(this).attr('data-full-data'));
                BindPaymentData(fullData);
            });
            $('#tblOldAgePayment').on('click', '.btn-delete', function () {
                var ID = JSON.parse($(this).attr('dataId'));
                confirmDelete(ID);
            });
            $('#search').on('click', function () {
                GetData();
            });

        })

        document.getElementById('downloadRegistrationForm').addEventListener('click', async function () {

            function getPDFSignatureSrc(canvasId, imgId) {
                var canvas = document.getElementById(canvasId);
                var img = document.getElementById(imgId);
                if (canvas && !canvas.hidden) {
                    var ctx = canvas.getContext('2d');
                    var buf = new Uint32Array(ctx.getImageData(0, 0, canvas.width, canvas.height).data.buffer);
                    if (buf.some(function (c) { return c !== 0; })) return canvas.toDataURL('image/png');
                }
                if (img && !img.hidden && img.src && img.src.length > 50) return img.src;
                return '';
            }

            await generateRegistrationPDF({
                filename:          ($('#patientName').val() || 'patient') + '.pdf',
                formTitle:         'OLD AGE ADMISSION FORM:',
                serialNo:          $('#serialNo').val(),
                date:              $('#adminssionDate').val(),
                addressLine1:      $('#customAdreesLine1').text().trim(),
                mobileNumbers:     $('#cutomMobileNumbers').text().trim(),
                email:             $('#customEmailAddress').text().trim(),
                fields: [
                    { label: 'Patient Name',         value: $('#patientName').val() },
                    { label: 'Address',              value: $('#address').val() },
                    { label: 'Patient Age',          value: $('#patientAge').val() },
                    { label: 'Patient Condition',    value: $('#patientCondition').val() },
                    { label: 'Customer Name',        value: $('#customerName').val() },
                    { label: 'Mobile No',            value: $('#mobileNo').val() },
                    { label: 'ID Proof',             value: $('#idProof')[0].files.length ? $('#idProof')[0].files[0].name : '(uploaded)' },
                    { label: 'Types of Service',     value: $('#typesOfService').val() },
                    { label: 'Registration Charges', value: $('#registrationCharges').val() },
                    { label: 'Monthly Payment Rs',   value: $('#monthlyPayment').val() },
                    { label: 'Period From',          value: $('#periodFrom').val() },
                    { label: 'To',                   value: $('#periodTo').val() }
                ],
                termsTitle:        'Terms and Conditions for Client:',
                terms: [
                    'We give with patients attender and nursing staff with emergency doctor visit.',
                    'Three times food and tea, coffee (daily changes of food).',
                    'We don\'t allow outside food and we don\'t provide any event foods for patients.',
                    'We don\'t gives any personal medication to patients (BP, SUGAR TABLETS DIAPER HAND GLOVES UNDER PAD/PATIENTS AU THINGS).',
                    'If the patient\'s discharge days are fewer than the advance payment balance, the remaining amount should be returned to the client.',
                    'In case patient death non refund advance amount.'
                ],
                declarationText:   'I hereby read, I heard all the above terms and conditions and agree to sign up with VEDHANTH Home Care for my service requirement.',
                clientSignSrc:     getPDFSignatureSrc('clientSignature', 'clientSignatureImage'),
                authorizedSignSrc: getPDFSignatureSrc('authorizedSignature', 'authorizedSignatureImage')
            });
        });

        $('#idProof').on('change', function (event) {
            var $input = $(this);
            var $status = $('#idProofStatus');
            OldAgeIdProof = '';
            $status.html('<span class="text-muted"><i class="fa-solid fa-spinner fa-spin"></i> Processing file, please wait...</span>');
            $status.show();
            $input.prop('disabled', true);

            ConvertToBase64(event.target).then(function (base64) {
                OldAgeIdProof = base64;
                var originalSizeMB = (event.target.files[0].size / (1024 * 1024)).toFixed(2);
                $status.html('<span class="text-success"><i class="fa-solid fa-check"></i> File ready (' + originalSizeMB + ' MB)</span>');
                $input.prop('disabled', false);
            }).catch(function (err) {
                OldAgeIdProof = '';
                $input.val('');
                $input.prop('disabled', false);
                $status.html('<span class="text-danger"><i class="fa-solid fa-triangle-exclamation"></i> ' + err + '</span>');
                alertMessage(typeof err === 'string' ? err : 'Failed to process file. Please try again.');
            });
        });

        document.getElementById('downloadIdProof').addEventListener('click', function () {
            if (OldAgeIdProof) {
                const mimeType = OldAgeIdProof.split("~")[0];
                const fileName = $('#patientName').val() + "_IdProof.";

                downloadFile(OldAgeIdProof.split("~")[1], mimeType, fileName);
            } else {
                alertMessage('No file available to download');
            }
        });
        function downloadFile(base64String, fileType, fileName) {
            const link = document.createElement('a');
            link.href = `data:${fileType};base64,${base64String}`;
            link.download = fileName + fileType.split("/")[1];
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

        function Clearfields() {
            $('.OldAgeIpfields').val('');
            clearSignature('authorizedSignature');
            clearSignature('clientSignature');
            $('#authorizedSignatureImage').prop('hidden', true);
            $('#authorizedSignature').prop('hidden', false);
            $('#clientSignature').prop('hidden', false);
            $('#clientSignatureImage').prop('hidden', true);
            OldAgeIdProof = '';
            $('#idProof').val('');
            $('#idProofStatus').hide().html('');
            GetSerialNo();
            $('#adminssionDate').val(formatDate(new Date()));
            $('#periodTo').val(formatDate(new Date()));
            $('#periodFrom').val(formatDate(new Date()));
            showPopup('oldAgePopup');
            // $('#oldAgePopup').modal('toggle');
        }

        function GetSerialNo() {
            $.get({
                url: '@Url.Action("GetLatestID", "OldAge")',
                success: function (response) {
                    $('#serialNo').val(response);
                },
                error: function (response) {
                }
            });
        }

        function isCanvasBlank(canvas) {
            const context = canvas.getContext('2d');
            const pixelBuffer = new Uint32Array(
                context.getImageData(0, 0, canvas.width, canvas.height).data.buffer
            );
            return !pixelBuffer.some(color => color !== 0);
        }


        function AddOldAge() {
            if (CheckEmptyFields()) {
                var data = {};
                data.Id = $('#oldAgePatientId').val();
                data.PatientName = $('#patientName').val();
                data.Address = $('#address').val();
                data.Age = $('#patientAge').val();
                data.Condition = $('#patientCondition').val();
                data.CustomerName = $('#customerName').val();
                data.MobileNo = $('#mobileNo').val();
                data.TypesofServices = $('#typesOfService').val();
                data.IdProof = OldAgeIdProof;
                data.PaymentStatus = "Pending";
                data.PeriodFrom = $('#periodFrom').val();
                data.PeriodTo = $('#periodTo').val();
                data.AdmissionDate = $('#adminssionDate').val();
                data.MonthlyPayment = $('#monthlyPayment').val();
                data.RegistrationCharges = $('#registrationCharges').val();
                var authorizedCanvas = $('#authorizedSignature')[0];
                var clientCanvas = $('#clientSignature')[0];
                // Only update signature if canvas is not blank, else keep previous value (from hidden img src)
                if (!isCanvasBlank(authorizedCanvas)) {
                    data.authorizedSign = authorizedCanvas.toDataURL("image/png").replace(/^data:image\/(png|jpg);base64,/, "");
                } else if ($('#authorizedSignatureImage').attr('src')) {
                    data.authorizedSign = $('#authorizedSignatureImage').attr('src').replace(/^data:image\/(png|jpg);base64,/, "");
                } else {
                    data.authorizedSign = "";
                }
                if (!isCanvasBlank(clientCanvas)) {
                    data.clientSign = clientCanvas.toDataURL("image/png").replace(/^data:image\/(png|jpg);base64,/, "");
                } else if ($('#clientSignatureImage').attr('src')) {
                    data.clientSign = $('#clientSignatureImage').attr('src').replace(/^data:image\/(png|jpg);base64,/, "");
                } else {
                    data.clientSign = "";
                }
                data.SUser = localStorage.getItem('username');
                $.ajax({
                    type: "POST",
                    url: '@Url.Action("AddorEditOldAge", "OldAge")',
                    data: data,
                    success: function (response) {
                        if (response) {
                            let msg = $('#oldAgePatientId').val() == '' ? "Data Added Successfully" : "Data Updated Successfully";
                            HidePopup('oldAgePopup');
                            msgPopup("success", msg);
                            GetData();

                            // Show client signature link
                            var baseUrl = '@Configuration["ClientSignatureBaseUrl"]';
                            var id = $('#oldAgePatientId').val() == '' ? response : $('#oldAgePatientId').val();
                            var link = baseUrl + '/OldAge/ClientSignature?id=' + id;
                            $('#clientSignatureLink').val(link);
                            $('#clientSignatureLinkContainer').show();
                        } else {
                            msgPopup("error", "Error! Please Try Again");
                        }
                    },
                    error: function (response) {
                        console.error(response);
                    }
                });
            }
        }

        function BindData(data) {
            $('#oldAgePatientId').val(data.id);
            $('#patientName').val(data.patientName);
            $('#address').val(data.address);
            $('#patientAge').val(data.age);
            $('#patientCondition').val(data.condition);
            $('#customerName').val(data.customerName);
            $('#mobileNo').val(data.mobileNo);
            $('#typesOfService').val(data.typesofServices);
            OldAgeIdProof = data.idProof;
            // data.PaymentStatus = "Pending";
            $('#periodFrom').val(formatDate(new Date(data.periodFrom)));
            $('#periodTo').val(formatDate(new Date(data.periodTo)));
            $('#adminssionDate').val(formatDate(new Date(data.admissionDate)));
            $('#monthlyPayment').val(data.monthlyPayment);
            $('#registrationCharges').val(data.registrationCharges);
            // Client Signature
            if (data.clientSign && data.clientSign.trim() !== "") {
                $('#clientSignatureImage').prop('hidden', false);
                $('#clientSignature').prop('hidden', true);
                $('#clientSignatureImage').attr('src', 'data:image/png;base64,' + data.clientSign);
            } else {
                $('#clientSignatureImage').prop('hidden', true);
                $('#clientSignature').prop('hidden', false);
                $('#clientSignatureImage').attr('src', '');
            }
            // Authorized Signature
            if (data.authorizedSign && data.authorizedSign.trim() !== "") {
                $('#authorizedSignatureImage').attr('src', 'data:image/png;base64,' + data.authorizedSign);
                $('#authorizedSignatureImage').prop('hidden', false);
                $('#authorizedSignature').prop('hidden', true);
            } else {
                $('#authorizedSignatureImage').prop('hidden', true);
                $('#authorizedSignature').prop('hidden', false);
                $('#authorizedSignatureImage').attr('src', '');
            }
            showPopup('oldAgePopup');
        }

        function confirmDelete(id) {
            $.alert({
                title: 'Alert',
                content: 'Are you sure want to delete ?',
                typeAnimated: true,
                backgroundDismiss: false,
                backgroundDismissAnimation: 'glow',
                boxWidth: '30%',
                useBootstrap: false,
                buttons: {
                    Yes: {
                        text: 'Yes',
                        btnClass: 'btn btn-success',
                        action: function () {
                            deleteData(id);
                        },
                    },
                    No: {
                        text: 'No',
                        btnClass: 'btn btn-warning',
                        action: function () {
                            return;
                        },
                    },
                },
            });
        }
        function deleteData(id) {
            $.ajax({
                type: "POST",
                url: '@Url.Action("DeleteData", "OldAge")',
                data: { id: id },
                success: function (response) {
                    if (response) {
                        msgPopup("success", "Data Deleted Successfully");
                        GetData();
                    } else {
                        msgPopup("error", "Error! Please Try Again");
                    }
                },
                error: function (response) {

                    console.error(response);
                }
            });
        }
         function copySignatureLink() {
            var copyText = document.getElementById('clientSignatureLink');
            copyText.select();
            copyText.setSelectionRange(0,99999);
            document.execCommand('copy');
            msgPopup('success', 'Link copied to clipboard!');
        }

        function GetData() {
            var table = $('#tblOldAge').DataTable();
            let startDate = $('#startDate').val();
            let endDate = $('#endDate').val();
            let user = $('#ddlUsers').val();
            $('#oldAgeLoader').show();
            $.get({
                url: '@Url.Action("GetData", "OldAge")',
                data: { startDate: startDate, endDate: endDate, username: user },
                success: function (response) {
                    table.clear().draw();
                    response.data.forEach(function (item) {
                        table.row.add([
                            item.patientName,
                            item.admissionDate ? item.admissionDate.split("T")[0] : null,
                            item.periodFrom ? item.periodFrom.split("T")[0] : null,
                            item.periodTo ? item.periodTo.split("T")[0] : null,
                            '<div class="contentCenter">' +
                            '<i class="fa fa-edit me-4 ml-2 btn-edit" style="color:green;cursor:pointer;" title="Edit" data-full-data=\'' + JSON.stringify(item).replace(/'/g, "&#39;") + '\'></i>' +
                            '<i class="fa-solid fa-paper-plane me-4 ml-2 btn-sign-link" style="color:#0d6efd;cursor:pointer;" title="Send Signature Link" data-id="' + item.id + '"></i>' +
                            '<i class="fa fa-trash ml-2 btn-delete" style="color:red;cursor:pointer;" title="Delete" dataId=\'' + JSON.stringify(item.id).replace(/'/g, "&#39;") + '\'></i>' +
                            '</div>'
                        ]).draw();
                    });
                    $('#oldAgeLoader').hide();
                    },
                    error: function (response) {
                    $('#oldAgeLoader').hide();
                    console.error(response);
                    }
            });
        }

</script>
<div id="clientSignatureLinkContainer" style="margin-top:10px;display:none;">
    <label>Share this link with the client to capture their signature:</label>
    <input type="text" id="clientSignatureLink" readonly style="width:80%;" />
    <button onclick="copySignatureLink()" class="btn btn-info">Copy Link</button>
</div>