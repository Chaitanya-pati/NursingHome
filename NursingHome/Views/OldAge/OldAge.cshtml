    <div class="col-md-12 container-fluid">
        <table id="tblOldAge" class="display table-bordered" style="width:100%">
            <thead>
                <tr>
                    <th>Patient Name</th>
                    <th>Admission Date</th>
                    <th>Payment Status</th>
                    <th>Period From</th>
                    <th>Period To</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
</body>
</html>
<script>
    var table = $('#tblOldAge').DataTable();
    $(document).ready(function () {
        GetData();
        $('#tblOldAge').on('click', '.btn-edit', function () {
            var fullData = JSON.parse($(this).attr('data-full-data'));
            BindData(fullData);
        });
        $('#tblOldAge').on('click', '.btn-delete', function () {
            var ID = JSON.parse($(this).attr('dataId'));
            confirmDelete(ID);
        });
       
    })

    document.getElementById('downloadRegistrationForm').addEventListener('click', function () {
        const element = document.querySelector('.registrationFormContent');
        element.style.transform = 'scale(0.8)';
        element.style.transformOrigin = 'top center';
        // Options for html2pdf
        const options = {
            margin: 0,
            filename: 'form.pdf',
            image: { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 3 },
            jsPDF: { unit: 'in', format: 'letter', orientation: 'portrait' }
        };

        // Generate PDF
        html2pdf().from(element).set(options).save();
    });
    var OldAgeIdProof;
    $('#idProof').on('change', function (event) {
        ConvertToBase64(event.target).then(base64 => {
            OldAgeIdProof = base64;
        });
    });

    function ConvertToBase64(input) {
        return new Promise((resolve, reject) => {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    var base64String = input.files[0].type + "~" + e.target.result.replace(/^data:.+\/(.+);base64,/, "");

                    resolve(base64String);
                }
                reader.onerror = function (error) {
                    reject(error);
                }
                reader.readAsDataURL(input.files[0]);
            } else {
                reject("No file selected");
            }
        });
    }

    document.getElementById('downloadIdProof').addEventListener('click', function () {
        if (OldAgeIdProof) {
            const mimeType = OldAgeIdProof.split("~")[0];
            const fileName = $('#patientName').val() + "_IdProof.";

            downloadFile(OldAgeIdProof.split("~")[1], mimeType, fileName);
        } else {
            alert('No file available to download');
        }
    });
    function downloadFile(base64String, fileType, fileName) {
        const link = document.createElement('a');
        link.href = `data:${fileType};base64,${base64String}`;
        link.download = fileName + fileType.split("/")[1];
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }
    function AddOldAge() {
        var data = {};
        data.Id = $('#oldAgePatientId').val();
        data.PatientName = $('#patientName').val();
        data.Address = $('#address').val();
        data.Age = $('#patientAge').val();
        data.Condition = $('#patientCondition').val();
        data.CustomerName = $('#customerName').val();
        data.MobileNo = $('#mobileNo').val();
        data.TypesofServices = $('#typesOfService').val();
        data.IdProof = OldAgeIdProof;
        data.PaymentStatus = "Pending";
        data.PeriodFrom = $('#periodFrom').val();
        data.PeriodTo = $('#periodTo').val();
        data.AdmissionDate = $('#adminssionDate').val();
        data.MonthlyPayment = $('#monthlyPayment').val();
        data.RegistrationCharges = $('#registrationCharges').val();
        $.ajax({
            type: "POST",
            url: '@Url.Action("AddorEditOldAge", "OldAge")',
            data: data,
            success: function (response) {

            },
            error: function (response) {

                console.error(response);
            }
        });
    }

    function GetData() {

        $.ajax({
            type: "POST",
            url: '@Url.Action("GetData", "OldAge")',
            // data: data,
            success: function (response) {
                table.clear();
                response.data.forEach(function (item) {
                    table.row.add([
                        item.patientName,
                        item.admissionDate.split("T")[0],
                        item.paymentStatus,
                        item.periodFrom.split("T")[0],
                        item.periodTo.split("T")[0],
                        '<i class="fa fa-edit me-4 ml-2 btn-edit" style="color:green" data-full-data=\'' + JSON.stringify(item).replace(/'/g, "&#39;") + '\'></i>' +
                        '<i class="fa fa-trash ml-2 btn-delete"  style="color:red" dataId=\'' + JSON.stringify(item.id).replace(/'/g, "&#39;") + '\'></i>'
                    ]).draw();
                });
            },
            error: function (response) {

                console.error(response);
            }
        });
    }


    function BindData(data) {
        $('#oldAgePatientId').val(data.id);
        $('#patientName').val(data.patientName);
        $('#address').val(data.address);
        $('#patientAge').val(data.age);
        $('#patientCondition').val(data.condition);
        $('#customerName').val(data.customerName);
        $('#mobileNo').val(data.mobileNo);
        $('#typesOfService').val(data.typesofServices);
        OldAgeIdProof = data.idProof;
        //  data.PaymentStatus = "Pending";
        $('#periodFrom').val(formatDate(new Date(data.periodFrom)));
        $('#periodTo').val(formatDate(new Date(data.periodTo)));
        $('#adminssionDate').val(formatDate(new Date(data.admissionDate)));
        $('#monthlyPayment').val(data.monthlyPayment);
        $('#registrationCharges').val(data.registrationCharges);
        $('#oldAgePopup').modal('toggle');
    }

    function confirmDelete(id){
        $.alert({
            title:'Alert',
            content: 'Are you sure want to delete ?',
            typeAnimated: true,
            backgroundDismiss: false,
            backgroundDismissAnimation: 'glow',
            boxWidth: '30%',
            useBootstrap: false,
            buttons: {
                Yes: {
                    text: 'Yes',
                    btnClass: 'btn btn-success',
                    action: function () {
                       deleteData(id);
                    },
                },
                No: {
                    text: 'No',
                    btnClass: 'btn btn-warning',
                    action: function () {
                      return;
                    },
                },
            },
        });
    }
    function deleteData(id){
        $.ajax({
            type: "POST",
            url: '@Url.Action("DeleteData", "OldAge")',
            data: {id:id},
            success: function (response) {

            },
            error: function (response) {

                console.error(response);
            }
        });
    }
</script>