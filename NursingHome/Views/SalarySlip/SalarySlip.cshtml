<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Salary Slip Generation</title>

    <!-- Include Bootstrap CSS -->
   
    <!-- Include Bootstrap DatePicker CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-datepicker@1.9.0/dist/css/bootstrap-datepicker.min.css">


    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.11/jspdf.plugin.autotable.min.js"></script>

    <!-- Bootstrap DatePicker JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-datepicker@1.9.0/dist/js/bootstrap-datepicker.min.js"></script>


</head>
<body>
<div class="container-fluid">
    <div>
        <h1>Salary Slip Generation</h1>

        <div class="row mt-4">
            <div class="col-md-12">
                <table id="salaryslipid" class="display table-bordered">
                    <thead>
                        <tr>
                            <th>Helper ID</th>
                            <th>Helper Name</th>
                            <th>Select Month</th>
                            <th>Generate Salary Slip</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Data will be populated here -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modal for salary slip details -->
    <div class="modal fade" id="salarySlipModal" tabindex="-1" aria-labelledby="salarySlipModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="salarySlipModalLabel">Salary Slip Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="salarySlipForm">
                        <div class="mb-3">
                            <label for="helperName" class="form-label">Name:</label>
                            <input type="text" id="helperName" class="form-control" readonly>
                        </div>
                        <div class="mb-3">
                            <label for="month" class="form-label">Month:</label>
                            <input type="text" id="month" class="form-control" readonly>
                        </div>
                        <div class="mb-3">
                            <label for="totalDaysWorked" class="form-label">Total Days Worked:</label>
                            <input type="text" id="totalDaysWorked" class="form-control" readonly>
                        </div>
                        <div class="mb-3">
                            <label for="basicSalary" class="form-label">Basic Salary:</label>
                            <input type="text" id="basicSalary" class="form-control" readonly>
                        </div>
                        <div class="mb-3">
                            <label for="netSalary" class="form-label">Net Salary:</label>
                            <input type="text" id="netSalary" class="form-control" readonly>
                        </div>
                        <button type="button" id="saveSalarySlip" class="btn btn-primary">Save and Generate PDF</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    </div>

    <script>
        

        $(document).ready(function () {
            let empid = '';
            let empname = '';
            let mothSal = '';
            let yearSal = '';
            let BasicSal = '';
            let NetSalaryslipamt = '';
            let EffectiveWorkingDays='';
            let TotalWorkingDysInMonth='';


            GetHelpers();

            // Initialize date picker
            $('body').on('focus', '.month-picker', function () {
                $(this).datepicker({
                    format: "mm-yyyy",
                    minViewMode: 1,
                    autoclose: true
                });
            });

            function GetHelpers() {
                let table = $('#salaryslipid').DataTable();
                $.ajax({
                    type: 'GET',
                    url: '@Url.Action("GetData", "Helpers")',
                    success: function (response) {
                        table.clear().draw();
                        $.each(response.data, function (index, item) {
                            table.row.add([
                                item.id,
                                item.name,
                                '<input type="text" class="form-control month-picker" placeholder="Select Month" />',
                                `<button class="btn btn-primary btn-generate" data-helper-id="${item.id}" data-helper-name="${item.name}" data-helper-salary="${item.salary || '0'}">Generate</button>`
                            ]).draw();
                        });
                    }
                });
            }

            // Event delegation for dynamically added buttons
            $('#salaryslipid').on('click', '.btn-generate', function () {
                let helperId = $(this).data('helper-id');
                let helperName = $(this).data('helper-name');
                let helperSalary = $(this).data('helper-salary');
                let month = $(this).closest('tr').find('.month-picker').val();

                $.ajax({
                    type: 'GET',
                    url: '@Url.Action("GetAttendanceAndNetSalary", "SalarySlip")',
                    data: {
                        employeeId: helperId,
                        month: month.split('-')[0],
                        year: month.split('-')[1]
                    },
                    success: function (response) {
                        empid = helperId;
                        empname = helperName;
                        mothSal = month;
                        yearSal = month.split('-')[1];
                        BasicSal = helperSalary;
                        NetSalaryslipamt = response.netSalary;
                        EffectiveWorkingDays = response.totalDaysWorked;
                        TotalWorkingDysInMonth = response.totalDaysInMonth;
                        $('#helperName').val(helperName);
                        $('#month').val(month);
                        $('#totalDaysWorked').val(response.totalDaysWorked);
                        $('#basicSalary').val(helperSalary);
                        $('#netSalary').val(response.netSalary);
                        
                        var modal = new bootstrap.Modal(document.getElementById('salarySlipModal'));
                        modal.show();
                    }
                });
            });
            const logo = 'data:image/jpeg;base64,';



            $('#saveSalarySlip').click(function () {
                const { jsPDF } = window.jspdf;
                const doc = new jsPDF({
                    orientation: 'portrait',
                    unit: 'mm',
                    format: 'a4'
                });

                const xOffset = 15;
                let yOffset = 20;
                const pageWidth = doc.internal.pageSize.getWidth();
                const pageHeight = doc.internal.pageSize.getHeight();

                // Add border around the document
                doc.rect(10, 10, pageWidth - 20, pageHeight - 20);

                const addPageIfNeeded = () => {
                    if (yOffset > pageHeight - 20) {
                        doc.addPage();
                        yOffset = 20;
                        doc.rect(10, 10, pageWidth - 20, pageHeight - 20);
                    }
                };

                // Add Logo (Centered)
                doc.addImage(logo, 'PNG', xOffset + 75, yOffset, 30, 30);
                yOffset += 45;

                // Add Header "Salary Slip"
                doc.setFontSize(18);
                doc.setFont('helvetica', 'bold');
                doc.text('Salary Slip', xOffset + 90, yOffset, { align: 'center' });
                yOffset += 10;

                // Add Company Details (Centered alignment)
                doc.setFontSize(14);
                doc.setFont('helvetica', 'bold');
                doc.text('Siddarth HOME CARE SERVICE', pageWidth / 2, yOffset, { align: 'center' });
                yOffset += 10;

                doc.setFontSize(11);
                doc.setFont('helvetica', 'normal');
                doc.text('No.69, New No.6/1, 1st Cross, 3rd Main Road, MathiKere, Banglure-590-054.', pageWidth / 2, yOffset, { align: 'center' });
                yOffset += 10;

                // Add Employee Details
                doc.setFontSize(12);
                yOffset += 10; // Add initial spacing before employee details

                doc.text(`Employee Name: ${empname}`, xOffset, yOffset);
                yOffset += 10; // Space after Employee Name
                doc.text(`Helper ID No: ${empid}`, xOffset, yOffset);
                yOffset += 10; // Space after Helper ID No
                doc.text(`Month/Year: ${mothSal} ${yearSal}`, xOffset, yOffset);
                yOffset += 10; // Space after Month/Year
                doc.text(`Total Working Days In A Month: ${TotalWorkingDysInMonth}`, xOffset, yOffset);
                yOffset += 10; // Space after Total Working Days
                doc.text(`Effective Working Days: ${EffectiveWorkingDays}`, xOffset, yOffset);
                yOffset += 10; // Space after Effective Working Days
                

                // Proceed with the rest of your code...


                // Table Headings and Borders
                const tableStartY = yOffset;
                doc.setFontSize(12);
                const headers = ['Earnings', 'Amount', 'Net Amount'];

                headers.forEach((header, index) => {
                    doc.text(header, xOffset + index * 60 + 2, yOffset + 5);
                });
                yOffset += 8;

                // Draw Top Border of Table
                doc.line(xOffset, tableStartY, xOffset + 180, tableStartY); // Top border of header

                // Prepare table data
                const salaryData = [
                    { label: 'Basic', amount: String(BasicSal), netAmount: String(NetSalaryslipamt) }
                ];

                // Draw Table Rows and Borders (Fixing column widths and borders)
                salaryData.forEach(row => {
                    addPageIfNeeded();

                    // Draw content
                    doc.text(row.label, xOffset + 2, yOffset + 5);
                    doc.text(row.amount, xOffset + 60 + 2, yOffset + 5);
                    doc.text(row.netAmount, xOffset + 120 + 2, yOffset + 5);

                    // Draw horizontal line after each row
                    doc.line(xOffset, yOffset + 8, xOffset + 180, yOffset + 8);

                    yOffset += 8;

                    // Draw vertical column borders for each row
                    doc.line(xOffset, tableStartY, xOffset, yOffset); // Left border
                    doc.line(xOffset + 60, tableStartY, xOffset + 60, yOffset); // After Earnings
                    doc.line(xOffset + 120, tableStartY, xOffset + 120, yOffset); // After Amount
                    doc.line(xOffset + 180, tableStartY, xOffset + 180, yOffset); // Right border
                });

                // Draw Bottom Border of the Table
                doc.line(xOffset, yOffset, xOffset + 180, yOffset);

                // Add Net Pay in Words (with adjustment)
                addPageIfNeeded();  // Ensure enough space
                yOffset += 10;  // Add spacing between table and Net Pay section
                doc.setFont('helvetica', 'bold');
                doc.setFontSize(12);

                const netPayInWords = convertNumberToWords(NetSalaryslipamt);
                doc.text(`Net Pay: ${netPayInWords}`, xOffset, yOffset);
                yOffset += 15;  // Add space for Net Pay section

                // Add Notes Section (with corrected alignment and spacing)
                doc.setFontSize(10);
                const notes = [
                    'Note: This is a computer-generated slip and does not require authentication.',
                    'This document contains confidential information. If you are not the intended recipient,',
                    'you are not authorized to use or disclose it in any form.',
                    'If you received this in error, please destroy it along with any copies and notify the',
                    'sender immediately.'
                ];

                notes.forEach(note => {
                    addPageIfNeeded();
                    doc.text(note, xOffset, yOffset);
                    yOffset += 5;
                });

                // Save the PDF
                doc.save('salary-slip.pdf');
            });



            // Example function to convert numbers to words (simplified version)
            function convertNumberToWords(amount) {
                // Implement your own logic to convert number to words
                // For simplicity, this example assumes amount is less than 100,000
                const words = ["", "One", "Two", "Three", "Four", "Five", "Six", "Seven", "Eight", "Nine", "Ten"];
                return words[amount] || amount.toString(); // Replace with full implementation as needed
            }




        });




    </script>

</body>
</html>
