@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@{
    ViewData["Title"] = "Nursing Home";
}
<style>
    .loader {
        display: none;
        position: fixed;
        z-index: 9999;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }

        .loader .spinner {
            border: 8px solid #f3f3f3;
            border-top: 8px solid #3498db;
            border-radius: 50%;
            width: 60px;
            height: 60px;
            animation: spin 1s linear infinite;
        }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    /* Card-view column labels for NursingHome grid (mobile) */
    @@media (max-width: 767px) {
        #tblNursingHome td:nth-child(1)::before { content: "Patient Name"; }
        #tblNursingHome td:nth-child(2)::before { content: "Helper Name"; }
        #tblNursingHome td:nth-child(3)::before { content: "Admission Date"; }
        #tblNursingHome td:nth-child(4)::before { content: "Payment Status"; }
        #tblNursingHome td:nth-child(5)::before { content: "Period From"; }
        #tblNursingHome td:nth-child(6)::before { content: "Period To"; }
        #tblNursingHome td:nth-child(7)::before { content: none; }

        /* Modal responsiveness */
        .custom-modal-dialog {
            width: 95% !important;
            margin: 1rem auto !important;
        }
        .modal-footer {
            flex-wrap: wrap;
            gap: 5px;
        }
        .modal-footer button {
            flex: 1 1 45%;
            margin: 2px;
        }
    }

    @@media (max-width: 576px) {
        .modal-footer button {
            flex: 1 1 100%;
        }
    }
</style>
<div id="nursingHomeLoader" class="loader"><div class="spinner"></div></div>
<div class="col-md-12">
    @Html.Partial("~/Partialviews/_SearchBar.cshtml")
</div>
<!-- Button to trigger modal -->
<div class="col-md-2 page-add-btn">
    <div class="container-fluid mt-2 mb-2">
        <button type="button" class="customBtn" onclick="verifyFace()">
            <i class="fa fa-add me-1"></i> Add
        </button>
    </div>
</div>
<!-- Modal -->
