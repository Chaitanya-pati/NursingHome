                                                    <div class="col-10">
                                                        <p>Signature of the Client &nbsp;&nbsp;&nbsp; <i class="fa-solid fa-arrows-rotate refreshSign" onclick="clearSignature('clientSignature')"></i></p>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-4"></div>
                                            <div class="signature-box col-4">
                                                <canvas id="authorizedSignature" class="signatureContainer"></canvas>
                                                <img id="authorizedSignatureImage" class="signatureContainerImage" hidden />
                                                <div class="row">
                                                    <p>Authorised Signatory &nbsp;&nbsp;&nbsp;<i class="fa-solid fa-arrows-rotate refreshSign" onclick="clearSignature('authorizedSignature')"></i></p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>

