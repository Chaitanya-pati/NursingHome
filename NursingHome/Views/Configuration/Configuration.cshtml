<div class="container-fluid">
    <div class="row">
        <div class="col-md-12 text-right mb-3">
            <button type="button" class="btn btn-success" data-toggle="modal" data-target="#AddAttendanceModal">
                Add Attendance
            </button>
        </div>
    </div>

    <!-- Modal for Creating and Editing Attendance -->
    <div class="modal fade" id="AddAttendanceModal" tabindex="-1" role="dialog" aria-labelledby="AttendanceModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="AttendanceModalLabel">Attendance Form</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <form id="attendanceForm" novalidate>
                        <div class="form-group">
                            <label for="HelperName">Select Helper</label>
                            <select class="form-select" id="HelperNameDDL" required></select>
                            <div class="invalid-feedback">Please select the Helper</div>
                        </div>

                        <div class="form-group">
                            <label for="PatientName">Select Patient</label>
                            <select class="form-select" id="PatientNameDDL" required></select>
                            <div class="invalid-feedback">Please select the Patient</div>
                        </div>

                        <div class="form-group">
                            <label for="AttendanceDate">Select Date</label>
                            <input type="datetime-local" class="form-control" id="AttendanceDate" required>
                            <div class="invalid-feedback">Please select the date</div>
                        </div>

                        <div class="form-group">
                            <label for="TotalHours">Total Work Hours</label>
                            <input type="text" class="form-control" id="TotalHours">
                        </div>

                        <div class="form-group">
                            <label for="Description">Enter Description</label>
                            <textarea class="form-control" id="Description" rows="4"></textarea>
                        </div>

                        <input type="hidden" id="AttendanceId">
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" id="SaveAttendanceData">Save</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Attendance Table -->
    <div class="row mt-4">
        <div class="col-md-12">
            <table id="tableAttendance" class="table table-bordered table-hover">
                <thead class="thead-light">
                    <tr>
                        <th>Helper Name</th>
                        <th>Patient Name</th>
                        <th>Date</th>
                        <th>Total Hours</th>
                        <th>Description</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        var table = $('#tableAttendance').DataTable();
        GetAttendanceData();

        $('#SaveAttendanceData').on('click', function () {
            var helperName = $('#HelperNameDDL').val();
            var patientName = $('#PatientNameDDL').val();
            var attendanceDate = $('#AttendanceDate').val();
            var totalHours = $('#TotalHours').val();
            var description = $('#Description').val();
            var attendanceId = $('#AttendanceId').val();

            if ($('#attendanceForm')[0].checkValidity()) {
                submitAttendanceData();
            } else {
                $('#attendanceForm').addClass('was-validated');
            }

            function submitAttendanceData() {
                $.ajax({
                    url: '/Attendance/AddOrEditAttendance',
                    type: 'POST',
                    data: {
                        HelperName: helperName,
                        PatientName: patientName,
                        AttendanceDate: attendanceDate,
                        TotalHours: totalHours,
                        Description: description,
                        ID: attendanceId
                    },
                    success: function (response) {
                        if (response) {
                            GetAttendanceData();
                            $('#AddAttendanceModal').modal('hide');
                        }
                    },
                    error: function (xhr, status, error) {
                        alert('An error occurred: ' + error);
                    }
                });
            }
        });

        $('#tableAttendance').on('click', '.btn-edit', function () {
            var fullData = JSON.parse($(this).attr('data-full-data'));
            BindAttendanceData(fullData);
        });

        $('#tableAttendance').on('click', '.btn-delete', function () {
            var ID = $(this).attr('data-id');
            confirmDelete(ID);
        });
    });

    function confirmDelete(id) {
        $.confirm({
            title: 'Confirm',
            content: 'Are you sure you want to delete this record?',
            buttons: {
                Yes: {
                    btnClass: 'btn btn-success',
                    action: function () {
                        deleteAttendance(id);
                    }
                },
                No: {
                    btnClass: 'btn btn-warning',
                    action: function () { }
                }
            }
        });
    }

    function BindAttendanceData(data) {
        $('#HelperNameDDL').val(data.helperName);
        $('#PatientNameDDL').val(data.patientName);
        $('#AttendanceDate').val(data.attendanceDate);
        $('#TotalHours').val(data.totalHours);
        $('#Description').val(data.description);
        $('#AttendanceId').val(data.id);
        $('#AddAttendanceModal').modal('show');
    }

    function deleteAttendance(id) {
        $.ajax({
            type: 'POST',
            url: '/Attendance/DeleteAttendance',
            data: { id: id },
            success: function (response) {
                GetAttendanceData();
            },
            error: function (response) {
                console.error(response);
            }
        });
    }

    function GetAttendanceData() {
        var table = $('#tableAttendance').DataTable();
        $.ajax({
            type: 'POST',
            url: '/Attendance/GetAttendanceData',
            success: function (response) {
                table.clear();
                response.data.forEach(function (item) {
                    table.row.add([
                        item.helperName,
                        item.patientName,
                        item.attendanceDate,
                        item.totalHours,
                        item.description,
                        `<div class="text-center">
                                <i class="fa fa-edit me-4 btn-edit" style="color:green" data-full-data='${JSON.stringify(item).replace(/'/g, "&#39;")}'></i>
                                <i class="fa fa-trash btn-delete" style="color:red" data-id="${item.id}"></i>
                            </div>`
                    ]).draw();
                });
            },
            error: function (xhr, status, error) {
                alert('An error occurred: ' + error);
            }
        });
    }
</script>
