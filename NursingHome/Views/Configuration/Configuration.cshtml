<div class="container-fluid">
    <div class="row">
        <div class="col-md-12 text-right mt-2">
            <button type="button" class="customBtn" data-toggle="modal" data-target="#cityModal" onclick="ClearFields()">
                <i class="fa fa-add me-1"></i>   Add New City
            </button>
        </div>
    </div>

    <div class="modal fade" id="cityModal" tabindex="-1" role="dialog" aria-labelledby="cityModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="cityModalLabel">User Information Form</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <form id="userForm" novalidate>
                        <input type="hidden" id="CityId" />
                        <div class="form-group">
                            <label for="Name">City Name</label>
                            <input type="text" class="form-control CityIpFileds" id="Name" required />
                            <div class="invalid-feedback">Please enter the city name.</div>
                        </div>
                        <div class="form-group">
                            <label for="Email">Email</label>
                            <input type="email" class="form-control CityIpFileds" id="Email" required />
                            <div class="invalid-feedback">Please enter a valid email address.</div>
                        </div>
                        <div class="form-group">
                            <label for="MobileNumber">Mobile Number</label>
                            <input type="tel" class="form-control CityIpFileds" id="MobileNumber" required />
                            <div class="invalid-feedback">Please enter a valid mobile number.</div>
                        </div>
                        <div class="form-group">
                            <label for="OfficeAddress">Office Address (Optional)</label>
                            <input type="text" class="form-control CityIpFileds" id="OfficeAddress" />
                        </div>
                        <div class="form-group">
                            <label for="ImageUpload">Upload Image (Optional)</label>
                            <input type="file" class="form-control-file" id="ImageUpload" accept="image/*" />
                        </div>
                        <input type="hidden" id="ImageBase64" />
                        
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" id="SaveCityData">Save</button>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-12">
            <table id="tablecity" class="display table-bordered">
                <thead class="thead-light">
                    <tr>
                        <th>Name</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<script>
    var BarCodeImg  = '';
    $(document).ready(function () {
        var table = $('#tablecity').DataTable();
        GetData();
        $('#ImageUpload').on('change', function (event) {
            ConvertToBase64(event.target).then(base64 => {
                BarCodeImg = base64;
            });
        });
        $('#SaveCityData').on('click', function () {
            var name = $('#Name').val();
            var email = $('#Email').val();
            var mobileNumber = $('#MobileNumber').val();
            var officeAddress = $('#OfficeAddress').val();
           // var imageInput = $('#ImageUpload')[0];
            var imageBase64 = BarCodeImg;
            var CityId = $('#CityId').val();

            if ($('#userForm')[0].checkValidity()) {
                    submitData();
            } else {
                $('#userForm').addClass('was-validated');
            }

            function submitData() {
                $.ajax({
                    url: '/Configuration/AddOrEditCity',
                    type: 'POST',
                    data: {
                        Name: name,
                        Email: email,
                        MobileNumbers: mobileNumber,
                        OfficeAddress: officeAddress,
                        ImageBase64: imageBase64,
                        Id: CityId
                    },
                    success: function (response) {
                        if (response) {
                            let msg = $('#CityId').val() == '' ? "Data Added Successfully" : "Data Updated Successfully";
                            msgPopup("success", msg);
                            GetData();
                            $('#cityModal').modal('hide');
                        }else{
                            msgPopup("error","Error! Please Try Again");
                        }
                    },
                    error: function (xhr, status, error) {
                        alert('An error occurred: ' + error);
                    }
                });
            }
        });

        $('#tablecity').on('click', '.btn-edit', function () {
            var fullData = JSON.parse($(this).attr('data-full-data'));
            BindData(fullData);
        });

        $('#tablecity').on('click', '.btn-delete', function () {
            var ID = JSON.parse($(this).attr('data-id'));
            confirmDelete(ID);
        });
    });

    function confirmDelete(id) {
        $.alert({
            title: 'Alert',
            content: 'Are you sure you want to delete?',
            buttons: {
                Yes: {
                    text: 'Yes',
                    btnClass: 'btn btn-success',
                    action: function () {
                        deleteData(id);
                    },
                },
                No: {
                    text: 'No',
                    btnClass: 'btn btn-warning'
                }
            }
        });
    }

    function BindData(data) {
        $('#Name').val(data.name);
        $('#Email').val(data.email);
        $('#OfficeAddress').val(data.officeAddress);
        $('#MobileNumber').val(data.mobileNumbers);
        $('#CityId').val(data.id);
        $('#cityModal').modal('show');
    }
    function ClearFields(){
        $('.CityIpFileds').val('');
        BarCodeImg = '';
    }
    function deleteData(id) {
        $.ajax({
            type: "POST",
            url: '/Configuration/DeleteCity',
            data: { id: id },
            success: function (response) {
                if(response){
                    msgPopup("success","Data Added Successfully");
                GetData();
                }else{
                    msgPopup("error","Error! Please Try Again");
                }
            },
            error: function (response) {
                console.error(response);
            }
        });
    }

    function GetData() {
        var table = $('#tablecity').DataTable();
        $.ajax({
            type: "POST",
            url: '/Configuration/GetCityData',
            success: function (response) {
                table.clear().draw();
                response.data.forEach(function (item) {
                    var mobileNumbers = item.mobileNumbers.split(',');
                    var mobileNumber1 = mobileNumbers[0] ? mobileNumbers[0] : '';
                    var mobileNumber2 = mobileNumbers[1] ? mobileNumbers[1] : '';

                    table.row.add([
                        item.name,
                        `<div class="contentCenter">
                                <i class="fa fa-edit me-4 btn-edit" style="color:green" data-full-data='${JSON.stringify(item).replace(/'/g, "&#39;")}'></i>
                                <i class="fa fa-trash btn-delete" style="color:red" data-id='${JSON.stringify(item.id).replace(/'/g, "&#39;")}'></i>
                            </div>`
                    ]).draw();
                });
            },
            error: function (xhr, status, error) {
                alert('An error occurred: ' + error);
            }
        });
    }
</script>
