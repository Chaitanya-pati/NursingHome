<style>
    .memo-container {
        width: 100%;
        margin: 0 auto;
    }

    .memo-header {
        text-align: center;
        font-size: 24px;
        font-weight: bold;
        margin-bottom: 20px;
    }

    .memo-form label {
        font-weight: bold;
    }

    .memo-form input, .memo-form textarea {
        width: 100%;
        border: none;
        border-bottom: 1px dotted #000;
        margin-bottom: 20px;
        font-size: 16px;
        padding: 5px 0;
    }

        .memo-form input[type="text"]::placeholder {
            color: #000;
        }

    .memo-form .currency-box {
        display: flex;
        align-items: center;
    }

        .memo-form .currency-box span {
            font-weight: bold;
            margin-right: 10px;
        }

    .currency-box input {
        width: auto;
        border: 1px solid #000;
        border-radius: 5px;
        padding: 5px;
        width: 80px;
        text-align: right;
    }

</style>
@*<div class="container-fluid">
    <button class="customBtn" onclick="OpenOldAgePaymentPopup()">OldAgePayment</button>
</div>
